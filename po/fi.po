msgid "An unexpected error occurred."
msgstr "Tapahtui odottamaton virhe."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Hyväksy sisäänkirjautuminen todennussovelluksessasi ja odota..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Todennettu käyttäjä {user} ei vastaa pyydettyä käyttäjää"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Todennettu käyttäjä {uuid} ei vastaa pyydettyä käyttäjää"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Todennus ei palauttanut päivitystunnusta. Yritä uudelleen."

msgid "Authentication failed (AADSTS{code})"
msgstr "Todennus epäonnistui (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Todennus epäonnistui selainpohjaisessa työnkulussa."

msgid "Authentication failed. Please contact your administrator."
msgstr "Todennus epäonnistui. Ota yhteyttä järjestelmänvalvojaan."

msgid "Authentication failed. Please try again."
msgstr "Todennus epäonnistui. Yritä uudelleen."

msgid "Authentication failed. Please try signing in again."
msgstr "Todennus epäonnistui. Yritä kirjautua sisään uudelleen."

msgid "Authentication failed: Authentication method not supported."
msgstr "Todennus epäonnistui: Todennusmenetelmää ei tueta."

msgid "Authentication failed: Configuration error."
msgstr "Todennus epäonnistui: Määritysvirhe."

msgid "Authentication failed: Cryptographic error."
msgstr "Todennus epäonnistui: salausvirhe."

msgid "Authentication failed: Invalid server response."
msgstr "Todennus epäonnistui: virheellinen palvelimen vastaus."

msgid "Authentication failed: Missing required data."
msgstr "Todennus epäonnistui: Vaadittuja tietoja puuttuu."

msgid "Authentication failed: Security hardware error."
msgstr "Todennus epäonnistui: suojauslaitteiston virhe."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Todennus epäonnistui: Todennuspalvelimeen ei saada yhteyttä."

msgid "Authentication failed: {error}"
msgstr "Todennus epäonnistui: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Todennusprosessi valmistui, mutta tunnuksen vaihto epäonnistui. Yritä uudelleen."

msgid "Authentication in progress."
msgstr "Todennus käynnissä."

msgid "Authentication incomplete. Please try again."
msgstr "Todennus jäi kesken. Yritä uudelleen."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Todennuspalvelu ei ole tilapäisesti käytettävissä. Yritä hetken kuluttua uudelleen."

msgid "Authentication service unavailable. Please try again later."
msgstr "Todennuspalvelu ei ole käytettävissä. Yritä myöhemmin uudelleen."

msgid "Authentication session corrupted. Please try again."
msgstr "Todennusistunto on vioittunut. Yritä uudelleen."

msgid "Authentication session data missing. Please try again."
msgstr "Todennusistunnon tiedot puuttuvat. Yritä uudelleen."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Todennusistunto palautti odottamattoman tilan. Yritä uudelleen."

msgid "Authentication timed out. Please try again."
msgstr "Todennus aikakatkaistiin. Yritä uudelleen."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Selaintodennuksen taustajärjestelmä ei ole käytettävissä. Yritä uudelleen."

msgid "Changing the password. Please wait..."
msgstr "Salasanaa vaihdetaan. Odota..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Valittu salasana on liian lyhyt! Vaaditaan 8 merkkiä."

msgid "Chosen pin is too short! {length} chars required."
msgstr "Valittu PIN-koodi on liian lyhyt! Vaaditaan {length} merkkiä."

msgid "Cloud Password:"
msgstr "Pilvisalasana:"

msgid "Code:"
msgstr "Koodi:"

msgid "Confirm PIN:"
msgstr "Vahvista PIN:"

msgid "Confirm password:"
msgstr "Vahvista salasana:"

msgid "Consent required. Please contact your administrator."
msgstr "Suostumus vaaditaan. Ota yhteyttä järjestelmänvalvojaasi."

msgid "Create a PIN to use in place of passwords."
msgstr "Luo PIN-koodi, jota voit käyttää salasanojen sijaan."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Laitteen rekisteröinti epäonnistui. Ota yhteyttä järjestelmänvalvojaan."

msgid "Device has been removed from the domain."
msgstr "Laite on poistettu toimialueelta."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Ota Bluetooth käyttöön kirjautuaksesi sisään puhelimellasi."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Rekisteröidään Hello-PIN-koodia. Odota..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Syötä määritysavain '{secret}' rekisteröidäksesi TOTP-todennussovelluksen. Käytä koodin nimenä arvoa '{issuer}' ja tunnisteena/nimenä arvoa '{account}'."

msgid "Entra Id Fido authentication failed."
msgstr "Entra ID FIDO -todennus epäonnistui."

msgid "Entra Id Password:"
msgstr "Entra ID:n salasana:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "FIDO-todennus ei ole käytettävissä. Kokeile toista todennusmenetelmää."

msgid "Failed to authenticate with Hello PIN."
msgstr "Todennus Hello-PIN-koodilla epäonnistui."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Todennus Hello-PIN-koodilla epäonnistui. Vielä yksi epäonnistunut yritys edellyttää monivaiheista todennusta ja Linux Hello -PIN-koodin nollaamista."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Hello TOTP -koodilla tunnistautuminen epäonnistui."

msgid "Failed to build regex: {error}"
msgstr "Säännöllisen lausekkeen muodostaminen epäonnistui: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Käyttäjän salasanan vaihtaminen epäonnistui: {msg}"

msgid "Failed to delete CSR key"
msgstr "CSR-avaimen poistaminen epäonnistui"

msgid "Failed to delete intune key"
msgstr "Intune-avaimen poistaminen epäonnistui"

msgid "Failed to generate QR code"
msgstr "QR-koodin luonti epäonnistui"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Toimialueeseen liittyminen epäonnistui. Ota yhteyttä järjestelmänvalvojaasi."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Hello-avaimen toimittaminen epäonnistui: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Laitteen määritysten tallentaminen epäonnistui. Ota yhteyttä järjestelmänvalvojaasi."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Laitteen tunnistetietojen tallentaminen epäonnistui. Ota yhteyttä järjestelmänvalvojaasi."

msgid "Fido PIN:"
msgstr "FIDO-PIN-koodi:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Himmelblau-todennus käynnistyy, odota hetki..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Himmelblau-todennuspalvelu ei tullut saataville ajoissa."

msgid "Himmelblau authentication service is unavailable."
msgstr "Himmelblau-todennuspalvelu ei ole käytettävissä."

msgid "Inputs did not match. Try again."
msgstr "Syötteet eivät täsmänneet. Yritä uudelleen."

msgid "Invalid credentials"
msgstr "Virheelliset kirjautumistiedot"

msgid "Multi-factor authentication required."
msgstr "Monivaiheinen todennus vaaditaan."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Monivaiheinen todennus vaaditaan. Yritä kirjautua uudelleen."

msgid "Network outage detected."
msgstr "Verkkokatkos havaittu."

msgid "New PIN:"
msgstr "Uusi PIN-koodi:"

msgid "New password:"
msgstr "Uusi salasana:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "Entra ID Hello -PIN-koodia ei annettu."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Entra Id Hello -vahvistuksen PIN-koodia ei annettu."

msgid "No Entra Id confirmation password was supplied."
msgstr "Entra ID -vahvistussalasanaa ei annettu."

msgid "No Entra Id password was supplied."
msgstr "Entra ID -salasanaa ei annettu."

msgid "No Hello TOTP code was supplied."
msgstr "Hello-TOTP-koodia ei annettu."

msgid "No input was supplied."
msgstr "Syötettä ei annettu."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Offline-tunnistautuminen on vanhentunut. Jatka yhdistämällä verkkoon."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Avaa Authenticator-sovellus ja syötä numero '{entropy}' kirjautuaksesi sisään."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Avaa todennussovelluksesi ja skannaa tämä QR-koodi rekisteröityäksesi. Syötä sitten luotu koodi.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN-koodissa ei saa käyttää toistuvia tai ennalta arvattavia numerosarjoja. Vältä esimerkiksi malleja, kuten '111111', '123456' tai '135791'."

msgid "PIN setup failed. Please try signing in again."
msgstr "PIN-koodin määrittäminen epäonnistui. Yritä kirjautua sisään uudelleen."

msgid "PIN:"
msgstr "PIN:"

msgid "Password change required. Please contact your administrator."
msgstr "Salasana on vaihdettava. Ota yhteyttä järjestelmänvalvojaan."

msgid "Password entry required."
msgstr "Salasanan syöttäminen vaaditaan."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Salasanan palautuksen rekisteröinti vaaditaan. Viimeistele määritys osoitteessa https://aka.ms/ssprsetup toisella laitteella ja yritä sitten uudelleen."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Anna Hello TOTP -koodisi Authenticator-sovelluksesta:"

msgid "Please insert your security key."
msgstr "Aseta suojausavaimesi."

msgid "Please select a device by touching one of them."
msgstr "Valitse laite koskettamalla jotakin niistä."

msgid "Please touch your security key."
msgstr "Kosketa suojausavaintasi."

msgid "Press enter to continue"
msgstr "Jatka painamalla Enter-näppäintä"

msgid "QR/Bluetooth authentication failed."
msgstr "QR-/Bluetooth-todennus epäonnistui."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Skannaa QR-koodi jatkaaksesi kirjautumista tai avaa tämä linkki toisella laitteella:\n"
"{complete}\n"
"Jos et voi skannata, siirry osoitteeseen:\n"
"{verification_uri}\n"
"Ja syötä koodi:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Skannaa todennussovelluksellasi"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Suojausavain- ja QR-/Bluetooth-todennus epäonnistui."

msgid "Security key authentication failed."
msgstr "Suojausavaimen todennus epäonnistui."

msgid "Session data corrupted. Please sign in again."
msgstr "Istunnon tiedot ovat vioittuneet. Kirjaudu uudelleen sisään."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Määritä PIN-koodi\n"
"Hello-PIN-koodi on nopea ja turvallinen tapa kirjautua laitteeseesi, sovelluksiin ja palveluihin."

msgid "TOTP Code:"
msgstr "TOTP-koodi:"

msgid "The minimum PIN length is {length} characters."
msgstr "PIN-koodin vähimmäispituus on {length} merkkiä."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Tämä komento vaihtaa paikallisen Hello-PIN-koodisi, EI Entra Id -salasanaasi."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Liian monta epäonnistunutta yritystä peräkkäin. Laitteesi on väliaikaisesti estetty. Irrota se ja liitä se uudelleen."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Liian monta epäonnistunutta yritystä. Laitteesi on estetty. Nollaa laite."

msgid "Too many failed user verification attempts."
msgstr "Liian monta epäonnistunutta käyttäjän vahvistusyritystä."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Liian monta virheellistä PIN-yritystä. Sinun on rekisteröitävä uusi Linux Hello -PIN."

msgid "Try again."
msgstr "Yritä uudelleen."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Odottamaton todennusvaihe. Yritä kirjautua uudelleen."

msgid "Unexpected error occurred."
msgstr "Tapahtui odottamaton virhe."

msgid "Unexpected error: {error}"
msgstr "Odottamaton virhe: {error}"

msgid "Unexpected select device notice"
msgstr "Odottamaton laitteen valintailmoitus"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Päivitä salasanasi\n"
"Sinun on päivitettävä salasanasi, koska tämä on\n"
"ensimmäinen kerta, kun kirjaudut sisään, tai koska\n"
"salasanasi on vanhentunut."

msgid "Use the Linux Hello PIN for this device."
msgstr "Käytä tämän laitteen Linux Hello -PIN-koodia."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Käytä Office 365- tai Microsoft-verkkokirjautumisesi salasanaa."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Käytä toisen laitteen selainta ja siirry osoitteeseen:\n"
"{verification_uri}\n"
"Anna koodi:\n"
"{user_code}"

msgid "Value:"
msgstr "Arvo:"

msgid "Waiting for browser authentication to complete..."
msgstr "Odotetaan selainautentikoinnin valmistumista..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Lähetimme tekstiviestin puhelimeesi {phone}. Anna koodi kirjautuaksesi sisään:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Soitamme työpuhelimeesi {phone}. Vastaa puheluun jatkaaksesi."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Soitamme puhelimeesi {phone}. Vastaa puheluun jatkaaksesi."

msgid "Wrong PIN! {message}"
msgstr "Väärä PIN-koodi! {message}"

msgid "Wrong user verification! {message}"
msgstr "Virheellinen käyttäjän vahvistus! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Sinulla on {attempts} yritys jäljellä."
msgstr[1] "Sinulla on {attempts} yritystä jäljellä."

msgid "Your session has expired. Please sign in again."
msgstr "Istuntosi on vanhentunut. Kirjaudu uudelleen."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Jos sinua pyydetään nyt antamaan pam_unix-salasana, jätä kehote huomiotta, palaa takaisin ja yritä uudelleen."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Eikö push-ilmoitusta tule? Tarkista mobiililaitteesi internet-yhteys."
