msgid "An unexpected error occurred."
msgstr "Došlo je do neočekivane greške."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Odobrite prijavu u svojoj aplikaciji za autentifikaciju, zatim sačekajte..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Autentifikovani korisnik {user} se ne podudara sa zahtevanim korisnikom"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Autentifikovani korisnik {uuid} ne odgovara zahtevanom korisniku"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Autentifikacija nije vratila token za osvežavanje. Pokušajte ponovo."

msgid "Authentication failed (AADSTS{code})"
msgstr "Autentifikacija nije uspela (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Autentifikacija u toku kroz pregledač nije uspela."

msgid "Authentication failed. Please contact your administrator."
msgstr "Autentifikacija nije uspela. Obratite se svom administratoru."

msgid "Authentication failed. Please try again."
msgstr "Autentifikacija nije uspela. Pokušajte ponovo."

msgid "Authentication failed. Please try signing in again."
msgstr "Autentifikacija nije uspela. Pokušajte ponovo da se prijavite."

msgid "Authentication failed: Authentication method not supported."
msgstr "Autentifikacija nije uspela: Metod autentifikacije nije podržan."

msgid "Authentication failed: Configuration error."
msgstr "Autentifikacija nije uspela: greška u konfiguraciji."

msgid "Authentication failed: Cryptographic error."
msgstr "Autentifikacija nije uspela: kriptografska greška."

msgid "Authentication failed: Invalid server response."
msgstr "Autentifikacija nije uspela: nevažeći odgovor servera."

msgid "Authentication failed: Missing required data."
msgstr "Autentifikacija nije uspela: nedostaju obavezni podaci."

msgid "Authentication failed: Security hardware error."
msgstr "Autentifikacija nije uspela: greška bezbednosnog hardvera."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Autentifikacija nije uspela: Nije moguće uspostaviti vezu sa serverom za autentifikaciju."

msgid "Authentication failed: {error}"
msgstr "Autentifikacija nije uspela: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Postupak autentifikacije je završen, ali razmena tokena nije uspela. Pokušajte ponovo."

msgid "Authentication in progress."
msgstr "Autentifikacija je u toku."

msgid "Authentication incomplete. Please try again."
msgstr "Autentifikacija nije dovršena. Pokušajte ponovo."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Usluga autentifikacije je privremeno nedostupna. Pokušajte ponovo uskoro."

msgid "Authentication service unavailable. Please try again later."
msgstr "Usluga autentifikacije nije dostupna. Pokušajte ponovo kasnije."

msgid "Authentication session corrupted. Please try again."
msgstr "Sesija za potvrdu identiteta je oštećena. Pokušajte ponovo."

msgid "Authentication session data missing. Please try again."
msgstr "Nedostaju podaci sesije za autentifikaciju. Pokušajte ponovo."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Sesija autentifikacije je vratila neočekivano stanje. Pokušajte ponovo."

msgid "Authentication timed out. Please try again."
msgstr "Vreme za autentifikaciju je isteklo. Pokušajte ponovo."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Pozadinski sistem za autentifikaciju putem pregledača nije dostupan. Pokušajte ponovo."

msgid "Changing the password. Please wait..."
msgstr "Lozinka se menja. Sačekajte..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Izabrana lozinka je prekratka! Potrebno je 8 znakova."

msgid "Chosen pin is too short! {length} chars required."
msgstr "Izabrani PIN je prekratak! Potrebno je {length} znakova."

msgid "Cloud Password:"
msgstr "Lozinka u oblaku:"

msgid "Code:"
msgstr "Kod:"

msgid "Confirm PIN:"
msgstr "Potvrdite PIN:"

msgid "Confirm password:"
msgstr "Potvrdite lozinku:"

msgid "Consent required. Please contact your administrator."
msgstr "Potrebna je saglasnost. Obratite se svom administratoru."

msgid "Create a PIN to use in place of passwords."
msgstr "Kreirajte PIN koji ćete koristiti umesto lozinki."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Registracija uređaja nije uspela. Obratite se svom administratoru."

msgid "Device has been removed from the domain."
msgstr "Uređaj je uklonjen iz domena."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Uključite Bluetooth da biste se prijavili pomoću telefona."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Registrovanje Hello PIN-a. Sačekajte..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Unesite ključ za podešavanje '{secret}' da biste registrovali TOTP aplikaciju za autentifikaciju. Koristite '{issuer}' kao naziv koda i '{account}' kao oznaku/naziv."

msgid "Entra Id Fido authentication failed."
msgstr "Entra ID FIDO autentifikacija nije uspela."

msgid "Entra Id Password:"
msgstr "Lozinka za Entra ID:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "FIDO autentifikacija nije dostupna. Pokušajte sa drugim metodom autentifikacije."

msgid "Failed to authenticate with Hello PIN."
msgstr "Autentifikacija pomoću Hello PIN-a nije uspela."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Autentifikacija pomoću Hello PIN-a nije uspela. Još jedan neuspeo pokušaj zahtevaće višefaktorsku autentifikaciju i resetovanje vašeg Linux Hello PIN-a."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Autentifikacija pomoću Hello TOTP koda nije uspela."

msgid "Failed to build regex: {error}"
msgstr "Neuspešno kreiranje regularnog izraza: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Promena korisničke lozinke nije uspela: {msg}"

msgid "Failed to delete CSR key"
msgstr "Brisanje CSR ključa nije uspelo"

msgid "Failed to delete intune key"
msgstr "Nije uspelo brisanje Intune ključa"

msgid "Failed to generate QR code"
msgstr "Generisanje QR koda nije uspelo"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Pridruživanje domenu nije uspelo. Obratite se svom administratoru."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Priprema Hello ključa nije uspela: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Čuvanje konfiguracije uređaja nije uspelo. Obratite se svom administratoru."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Nije uspelo čuvanje akreditiva uređaja. Obratite se svom administratoru."

msgid "Fido PIN:"
msgstr "FIDO PIN:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Himmelblau autentifikacija se pokreće, sačekajte..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Usluga za autentifikaciju Himmelblau nije postala dostupna na vreme."

msgid "Himmelblau authentication service is unavailable."
msgstr "Usluga autentifikacije Himmelblau nije dostupna."

msgid "Inputs did not match. Try again."
msgstr "Unosi se ne podudaraju. Pokušajte ponovo."

msgid "Invalid credentials"
msgstr "Nevažeći akreditivi"

msgid "Multi-factor authentication required."
msgstr "Potrebna je višefaktorska autentifikacija."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Potrebna je višefaktorska autentifikacija. Pokušajte ponovo da se prijavite."

msgid "Network outage detected."
msgstr "Otkriven je prekid mreže."

msgid "New PIN:"
msgstr "Novi PIN:"

msgid "New password:"
msgstr "Nova lozinka:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "Nije dostavljen Entra ID Hello PIN."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Nije unet PIN za potvrdu za Entra Id Hello."

msgid "No Entra Id confirmation password was supplied."
msgstr "Nije uneta lozinka za potvrdu Entra ID-a."

msgid "No Entra Id password was supplied."
msgstr "Nije navedena lozinka za Entra ID."

msgid "No Hello TOTP code was supplied."
msgstr "Nije unet Hello TOTP kod."

msgid "No input was supplied."
msgstr "Nije unet nijedan podatak."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Autentifikacija van mreže je istekla. Povežite se na mrežu da biste nastavili."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Otvorite aplikaciju Authenticator i unesite broj '{entropy}' da biste se prijavili."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Otvorite aplikaciju za autentifikaciju i skenirajte ovaj QR kôd da biste se registrovali. Zatim unesite generisani kôd.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN ne sme da sadrži ponavljajuće ili predvidljive nizove. Izbegavajte obrasce poput '111111', '123456' ili '135791'."

msgid "PIN setup failed. Please try signing in again."
msgstr "Podešavanje PIN-a nije uspelo. Pokušajte ponovo da se prijavite."

msgid "PIN:"
msgstr "PIN:"

msgid "Password change required. Please contact your administrator."
msgstr "Potrebna je promena lozinke. Obratite se svom administratoru."

msgid "Password entry required."
msgstr "Potreban je unos lozinke."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Potrebna je registracija za resetovanje lozinke. Dovršite podešavanje na https://aka.ms/ssprsetup sa drugog uređaja, a zatim pokušajte ponovo."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Molimo unesite svoj Hello TOTP kod iz aplikacije Authenticator:"

msgid "Please insert your security key."
msgstr "Umetnite svoj bezbednosni ključ."

msgid "Please select a device by touching one of them."
msgstr "Izaberite uređaj tako što ćete dodirnuti jedan od njih."

msgid "Please touch your security key."
msgstr "Dodirnite svoj bezbednosni ključ."

msgid "Press enter to continue"
msgstr "Pritisnite Enter za nastavak"

msgid "QR/Bluetooth authentication failed."
msgstr "QR/Bluetooth autentifikacija nije uspela."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Skenirajte QR kod da biste nastavili prijavu ili otvorite ovaj link na drugom uređaju:\n"
"{complete}\n"
"Ako ne možete da skenirate, posetite:\n"
"{verification_uri}\n"
"I unesite kod:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Skenirajte pomoću svoje aplikacije za autentifikaciju"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Autentifikacija bezbednosnim ključem i QR/Bluetooth autentifikacija nisu uspele."

msgid "Security key authentication failed."
msgstr "Autentifikacija bezbednosnim ključem nije uspela."

msgid "Session data corrupted. Please sign in again."
msgstr "Podaci sesije su oštećeni. Prijavite se ponovo."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Podesite PIN\n"
"Hello PIN je brz i bezbedan način da se prijavite na svoj uređaj, aplikacije i usluge."

msgid "TOTP Code:"
msgstr "TOTP kod:"

msgid "The minimum PIN length is {length} characters."
msgstr "Minimalna dužina PIN-a je {length} znakova."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ova naredba menja vaš lokalni Hello PIN, a NE vašu lozinku za Entra Id."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Previše neuspešnih pokušaja zaredom. Vaš uređaj je privremeno blokiran. Molimo vas da ga isključite iz priključka i ponovo priključite."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Previše neuspešnih pokušaja. Vaš uređaj je blokiran. Resetujte ga."

msgid "Too many failed user verification attempts."
msgstr "Previše neuspelih pokušaja verifikacije korisnika."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Previše pogrešnih pokušaja unosa PIN-a. Moraćete da registrujete novi Linux Hello PIN."

msgid "Try again."
msgstr "Pokušajte ponovo."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Neočekivan korak autentifikacije. Pokušajte ponovo da se prijavite."

msgid "Unexpected error occurred."
msgstr "Došlo je do neočekivane greške."

msgid "Unexpected error: {error}"
msgstr "Neočekivana greška: {error}"

msgid "Unexpected select device notice"
msgstr "Neočekivano obaveštenje o izboru uređaja"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Ažurirajte lozinku\n"
"Morate da ažurirate lozinku zato što se prijavljujete\n"
"prvi put ili zato što je vaša lozinka istekla."

msgid "Use the Linux Hello PIN for this device."
msgstr "Koristite Linux Hello PIN za ovaj uređaj."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Koristite lozinku za prijavljivanje na Office 365 ili Microsoft onlajn."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Pomoću pregledača na drugom uređaju posetite:\n"
"{verification_uri}\n"
"I unesite kod:\n"
"{user_code}"

msgid "Value:"
msgstr "Vrednost:"

msgid "Waiting for browser authentication to complete..."
msgstr "Čeka se završetak autentifikacije u pregledaču..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Poslali smo SMS na vaš telefon {phone}. Unesite kod da biste se prijavili:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Pozivamo vaš službeni telefon {phone}. Odgovorite na poziv da biste nastavili."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Pozivamo vaš telefon {phone}. Odgovorite na poziv da biste nastavili."

msgid "Wrong PIN! {message}"
msgstr "Pogrešan PIN! {message}"

msgid "Wrong user verification! {message}"
msgstr "Neispravna verifikacija korisnika! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Imate još {attempts} pokušaj."
msgstr[1] "Imate još {attempts} pokušaja."
msgstr[2] "Imate još {attempts} pokušaja."

msgid "Your session has expired. Please sign in again."
msgstr "Vaša sesija je istekla. Prijavite se ponovo."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Ako sada dobijete upit za lozinku od pam_unix, zanemarite taj upit, vratite se i pokušajte ponovo."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Nema push obaveštenja? Proverite internet vezu na mobilnom uređaju."
