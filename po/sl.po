msgid "An unexpected error occurred."
msgstr "Prišlo je do nepričakovane napake."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Odobrite prijavo v aplikaciji za preverjanje pristnosti, nato počakajte ..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Overjeni uporabnik {user} se ne ujema z zahtevanim uporabnikom"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Overjeni uporabnik {uuid} se ne ujema z zahtevanim uporabnikom"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Preverjanje pristnosti ni vrnilo žetona za osvežitev. Poskusite znova."

msgid "Authentication failed (AADSTS{code})"
msgstr "Preverjanje pristnosti ni uspelo (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Preverjanje pristnosti v toku brskalnika ni uspelo."

msgid "Authentication failed. Please contact your administrator."
msgstr "Preverjanje pristnosti ni uspelo. Obrnite se na skrbnika."

msgid "Authentication failed. Please try again."
msgstr "Preverjanje pristnosti ni uspelo. Poskusite znova."

msgid "Authentication failed. Please try signing in again."
msgstr "Preverjanje pristnosti ni uspelo. Poskusite se znova prijaviti."

msgid "Authentication failed: Authentication method not supported."
msgstr "Preverjanje pristnosti ni uspelo: način preverjanja pristnosti ni podprt."

msgid "Authentication failed: Configuration error."
msgstr "Preverjanje pristnosti ni uspelo: napaka v konfiguraciji."

msgid "Authentication failed: Cryptographic error."
msgstr "Preverjanje pristnosti ni uspelo: kriptografska napaka."

msgid "Authentication failed: Invalid server response."
msgstr "Preverjanje pristnosti ni uspelo: neveljaven odgovor strežnika."

msgid "Authentication failed: Missing required data."
msgstr "Preverjanje pristnosti ni uspelo: Manjkajo zahtevani podatki."

msgid "Authentication failed: Security hardware error."
msgstr "Preverjanje pristnosti ni uspelo: napaka varnostne strojne opreme."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Preverjanje pristnosti ni uspelo: Strežnik za preverjanje pristnosti ni dosegljiv."

msgid "Authentication failed: {error}"
msgstr "Preverjanje pristnosti ni uspelo: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Potek preverjanja pristnosti je bil zaključen, vendar izmenjava žetona ni uspela. Poskusite znova."

msgid "Authentication in progress."
msgstr "Preverjanje pristnosti je v teku."

msgid "Authentication incomplete. Please try again."
msgstr "Preverjanje pristnosti ni dokončano. Poskusite znova."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Storitev za preverjanje pristnosti trenutno ni na voljo. Poskusite znova čez nekaj trenutkov."

msgid "Authentication service unavailable. Please try again later."
msgstr "Storitev za preverjanje pristnosti ni na voljo. Poskusite znova pozneje."

msgid "Authentication session corrupted. Please try again."
msgstr "Seja preverjanja pristnosti je poškodovana. Poskusite znova."

msgid "Authentication session data missing. Please try again."
msgstr "Podatki seje za preverjanje pristnosti manjkajo. Poskusite znova."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Seja preverjanja pristnosti je vrnila nepričakovano stanje. Poskusite znova."

msgid "Authentication timed out. Please try again."
msgstr "Čas za preverjanje pristnosti je potekel. Poskusite znova."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Zaledje za overjanje v brskalniku ni na voljo. Poskusite znova."

msgid "Changing the password. Please wait..."
msgstr "Spreminjanje gesla. Počakajte ..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Izbrano geslo je prekratko! Zahtevanih je 8 znakov."

msgid "Chosen pin is too short! {length} chars required."
msgstr "Izbrana koda PIN je prekratka! Potrebnih je {length} znakov."

msgid "Cloud Password:"
msgstr "Geslo v oblaku:"

msgid "Code:"
msgstr "Koda:"

msgid "Confirm PIN:"
msgstr "Potrdite PIN:"

msgid "Confirm password:"
msgstr "Potrdite geslo:"

msgid "Consent required. Please contact your administrator."
msgstr "Potrebno je soglasje. Obrnite se na skrbnika."

msgid "Create a PIN to use in place of passwords."
msgstr "Ustvarite PIN, ki ga boste uporabljali namesto gesel."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Včlanitev naprave ni uspela. Obrnite se na skrbnika."

msgid "Device has been removed from the domain."
msgstr "Naprava je bila odstranjena iz domene."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Omogočite Bluetooth, da se prijavite s telefonom."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Vpisovanje kode PIN za Hello. Prosimo, počakajte ..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Vnesite nastavitveni ključ »{secret}« za registracijo aplikacije TOTP Authenticator. Za ime kode uporabite »{issuer}«, za oznako/ime pa »{account}«."

msgid "Entra Id Fido authentication failed."
msgstr "Preverjanje pristnosti Entra ID FIDO ni uspelo."

msgid "Entra Id Password:"
msgstr "Geslo za Entra ID:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "Preverjanje pristnosti FIDO ni na voljo. Poskusite uporabiti drug način preverjanja pristnosti."

msgid "Failed to authenticate with Hello PIN."
msgstr "Preverjanje pristnosti s kodo PIN Hello ni uspelo."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Preverjanje pristnosti s kodo PIN za Hello ni uspelo. Še en neuspešen poskus bo zahteval večfaktorsko preverjanje pristnosti in ponastavitev vaše kode PIN za Linux Hello."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Preverjanje pristnosti s kodo Hello TOTP ni uspelo."

msgid "Failed to build regex: {error}"
msgstr "Ni bilo mogoče ustvariti regularnega izraza: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Gesla uporabnika ni bilo mogoče spremeniti: {msg}"

msgid "Failed to delete CSR key"
msgstr "Brisanje ključa CSR ni uspelo"

msgid "Failed to delete intune key"
msgstr "Ključa Intune ni bilo mogoče izbrisati"

msgid "Failed to generate QR code"
msgstr "Kode QR ni bilo mogoče ustvariti"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Pridružitev domeni ni uspela. Obrnite se na skrbnika."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Priprava ključa Hello ni uspela: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Shranjevanje konfiguracije naprave ni uspelo. Obrnite se na skrbnika."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Shranjevanje poverilnic naprave ni uspelo. Obrnite se na skrbnika."

msgid "Fido PIN:"
msgstr "PIN za FIDO:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Preverjanje pristnosti Himmelblau se začenja, počakajte..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Storitev preverjanja pristnosti Himmelblau ni postala pravočasno na voljo."

msgid "Himmelblau authentication service is unavailable."
msgstr "Storitev preverjanja pristnosti Himmelblau ni na voljo."

msgid "Inputs did not match. Try again."
msgstr "Vnosi se niso ujemali. Poskusite znova."

msgid "Invalid credentials"
msgstr "Neveljavne poverilnice"

msgid "Multi-factor authentication required."
msgstr "Zahtevano je večkratno preverjanje pristnosti."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Potrebno je večkratno preverjanje pristnosti. Poskusite se znova vpisati."

msgid "Network outage detected."
msgstr "Zaznan je izpad omrežja."

msgid "New PIN:"
msgstr "Nova koda PIN:"

msgid "New password:"
msgstr "Novo geslo:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "PIN za Entra ID Hello ni bil naveden."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Potrditvena koda PIN za Entra ID Hello ni bila podana."

msgid "No Entra Id confirmation password was supplied."
msgstr "Potrditveno geslo za Entra ID ni bilo navedeno."

msgid "No Entra Id password was supplied."
msgstr "Geslo za Entra ID ni bilo podano."

msgid "No Hello TOTP code was supplied."
msgstr "Koda Hello TOTP ni bila posredovana."

msgid "No input was supplied."
msgstr "Vnos ni bil podan."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Preverjanje pristnosti brez povezave je poteklo. Za nadaljevanje se povežite z omrežjem."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Odprite aplikacijo Authenticator in vnesite številko »{entropy}« za prijavo."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Odprite aplikacijo za preverjanje pristnosti in optično preberite to kodo QR za registracijo. Nato vnesite ustvarjeno kodo.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN ne sme vsebovati ponavljajočih se ali predvidljivih zaporedij. Izogibajte se vzorcem, kot so »111111«, »123456« ali »135791«."

msgid "PIN setup failed. Please try signing in again."
msgstr "Nastavitev kode PIN ni uspela. Poskusite se znova vpisati."

msgid "PIN:"
msgstr "PIN:"

msgid "Password change required. Please contact your administrator."
msgstr "Potrebna je sprememba gesla. Obrnite se na svojega skrbnika."

msgid "Password entry required."
msgstr "Zahtevan je vnos gesla."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Potrebna je registracija za ponastavitev gesla. Dokončajte nastavitev na https://aka.ms/ssprsetup v drugi napravi, nato poskusite znova."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Vnesite svojo kodo Hello TOTP iz aplikacije Authenticator:"

msgid "Please insert your security key."
msgstr "Vstavite svoj varnostni ključ."

msgid "Please select a device by touching one of them."
msgstr "Izberite napravo tako, da se dotaknete ene od njih."

msgid "Please touch your security key."
msgstr "Dotaknite se varnostnega ključa."

msgid "Press enter to continue"
msgstr "Pritisnite Enter za nadaljevanje"

msgid "QR/Bluetooth authentication failed."
msgstr "Preverjanje pristnosti s kodo QR/Bluetooth ni uspelo."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Optično preberite kodo QR, da nadaljujete prijavo, ali odprite to povezavo na drugi napravi:\n"
"{complete}\n"
"Če kode ne morete optično prebrati, obiščite:\n"
"{verification_uri}\n"
"In vnesite kodo:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Optično preberite z aplikacijo za preverjanje pristnosti"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Preverjanje pristnosti z varnostnim ključem in prek QR/Bluetooth ni uspelo."

msgid "Security key authentication failed."
msgstr "Preverjanje pristnosti z varnostnim ključem ni uspelo."

msgid "Session data corrupted. Please sign in again."
msgstr "Podatki seje so poškodovani. Znova se prijavite."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Nastavite PIN\n"
"Hello PIN je hiter in varen način za prijavo v vašo napravo, aplikacije in storitve."

msgid "TOTP Code:"
msgstr "Koda TOTP:"

msgid "The minimum PIN length is {length} characters."
msgstr "Najmanjša dolžina kode PIN je {length} znakov."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ta ukaz spremeni vaš lokalni Hello PIN, NE vašega gesla za Entra ID."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Preveč zaporednih neuspešnih poskusov. Vaša naprava je bila začasno blokirana. Odklopite jo in jo ponovno priklopite."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Preveč neuspešnih poskusov. Vaša naprava je bila blokirana. Ponastavite jo."

msgid "Too many failed user verification attempts."
msgstr "Preveč neuspelih poskusov preverjanja uporabnika."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Preveč napačnih poskusov vnosa kode PIN. Registrirati boste morali novo kodo PIN za Linux Hello."

msgid "Try again."
msgstr "Poskusite znova."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Nepričakovan korak preverjanja pristnosti. Poskusite se znova prijaviti."

msgid "Unexpected error occurred."
msgstr "Prišlo je do nepričakovane napake."

msgid "Unexpected error: {error}"
msgstr "Nepričakovana napaka: {error}"

msgid "Unexpected select device notice"
msgstr "Nepričakovano obvestilo o izbiri naprave"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Posodobite svoje geslo\n"
"Geslo morate posodobiti, ker se prijavljate prvič ali ker je vaše geslo poteklo."

msgid "Use the Linux Hello PIN for this device."
msgstr "Uporabite PIN za Linux Hello za to napravo."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Uporabite geslo za prijavo v Office 365 ali Microsoft Online."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Na drugi napravi v brskalniku obiščite:\n"
"{verification_uri}\n"
"In vnesite kodo:\n"
"{user_code}"

msgid "Value:"
msgstr "Vrednost:"

msgid "Waiting for browser authentication to complete..."
msgstr "Čakanje na dokončanje preverjanja pristnosti v brskalniku..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Na vaš telefon {phone} smo poslali SMS. Za prijavo vnesite kodo:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Kličemo vaš službeni telefon {phone}. Za nadaljevanje se oglasite."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Kličemo vas na telefon {phone}. Odgovorite na klic, če želite nadaljevati."

msgid "Wrong PIN! {message}"
msgstr "Napačen PIN! {message}"

msgid "Wrong user verification! {message}"
msgstr "Napačno preverjanje uporabnika! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Imate še {attempts} poskus."
msgstr[1] "Imate še {attempts} poskusa."
msgstr[2] "Imate še {attempts} poskuse."
msgstr[3] "Imate še {attempts} poskusov."

msgid "Your session has expired. Please sign in again."
msgstr "Vaša seja je potekla. Znova se prijavite."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Če ste zdaj pozvani k vnosu gesla iz pam_unix, prezrite ta poziv, se vrnite in poskusite znova."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Ni potisnega obvestila? Preverite internetno povezavo svoje mobilne naprave."
