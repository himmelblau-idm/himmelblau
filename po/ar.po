msgid "An unexpected error occurred."
msgstr "حدث خطأ غير متوقع."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "وافق على تسجيل الدخول في تطبيق المصادقة، ثم انتظر..."

msgid "Authenticated user {user} does not match requested user"
msgstr "المستخدم المصادق عليه {user} لا يطابق المستخدم المطلوب"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "المستخدم المصادق عليه {uuid} لا يطابق المستخدم المطلوب"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "لم تُرجِع المصادقة رمزًا مميزًا للتحديث. يُرجى المحاولة مرة أخرى."

msgid "Authentication failed (AADSTS{code})"
msgstr "فشلت المصادقة (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "فشلت المصادقة في مسار المتصفح."

msgid "Authentication failed. Please contact your administrator."
msgstr "فشلت المصادقة. يُرجى الاتصال بالمسؤول."

msgid "Authentication failed. Please try again."
msgstr "فشلت المصادقة. يُرجى المحاولة مرة أخرى."

msgid "Authentication failed. Please try signing in again."
msgstr "فشلت المصادقة. يُرجى محاولة تسجيل الدخول مرة أخرى."

msgid "Authentication failed: Authentication method not supported."
msgstr "فشلت المصادقة: طريقة المصادقة غير مدعومة."

msgid "Authentication failed: Configuration error."
msgstr "فشلت المصادقة: خطأ في التكوين."

msgid "Authentication failed: Cryptographic error."
msgstr "فشلت المصادقة: خطأ في التشفير."

msgid "Authentication failed: Invalid server response."
msgstr "فشلت المصادقة: استجابة الخادم غير صالحة."

msgid "Authentication failed: Missing required data."
msgstr "فشلت المصادقة: البيانات المطلوبة مفقودة."

msgid "Authentication failed: Security hardware error."
msgstr "فشلت المصادقة: خطأ في جهاز الأمان."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "فشلت المصادقة: تعذر الوصول إلى خادم المصادقة."

msgid "Authentication failed: {error}"
msgstr "فشلت المصادقة: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "اكتمل تدفق المصادقة، لكن فشل تبادل الرمز المميز. يُرجى المحاولة مرة أخرى."

msgid "Authentication in progress."
msgstr "المصادقة قيد التقدم."

msgid "Authentication incomplete. Please try again."
msgstr "المصادقة غير مكتملة. يُرجى المحاولة مرة أخرى."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "خدمة المصادقة غير متاحة مؤقتًا. يُرجى المحاولة مرة أخرى بعد قليل."

msgid "Authentication service unavailable. Please try again later."
msgstr "خدمة المصادقة غير متوفرة. يرجى المحاولة مرة أخرى لاحقًا."

msgid "Authentication session corrupted. Please try again."
msgstr "جلسة المصادقة تالفة. يُرجى المحاولة مرة أخرى."

msgid "Authentication session data missing. Please try again."
msgstr "بيانات جلسة المصادقة مفقودة. يُرجى المحاولة مرة أخرى."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "أرجعت جلسة المصادقة حالة غير متوقعة. يُرجى المحاولة مرة أخرى."

msgid "Authentication timed out. Please try again."
msgstr "انتهت مهلة المصادقة. يُرجى المحاولة مرة أخرى."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "واجهة مصادقة المتصفح الخلفية غير متاحة. يُرجى المحاولة مرة أخرى."

msgid "Changing the password. Please wait..."
msgstr "جارٍ تغيير كلمة المرور. يُرجى الانتظار..."

msgid "Chosen password is too short! 8 chars required."
msgstr "كلمة المرور المختارة قصيرة جدًا! يلزم إدخال 8 أحرف."

msgid "Chosen pin is too short! {length} chars required."
msgstr "رقم التعريف الشخصي المختار قصير جدًا! يلزم {length} أحرف."

msgid "Cloud Password:"
msgstr "كلمة مرور السحابة:"

msgid "Code:"
msgstr "الرمز:"

msgid "Confirm PIN:"
msgstr "تأكيد رمز PIN:"

msgid "Confirm password:"
msgstr "تأكيد كلمة المرور:"

msgid "Consent required. Please contact your administrator."
msgstr "الموافقة مطلوبة. يُرجى الاتصال بالمسؤول."

msgid "Create a PIN to use in place of passwords."
msgstr "أنشئ رقم تعريف شخصيًا لاستخدامه بدلًا من كلمات المرور."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "فشل تسجيل الجهاز. يُرجى التواصل مع المسؤول."

msgid "Device has been removed from the domain."
msgstr "تمت إزالة الجهاز من المجال."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "فعّل Bluetooth لتسجيل الدخول باستخدام هاتفك."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "جارٍ تسجيل رقم التعريف الشخصي لـ Hello. يُرجى الانتظار..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "أدخل مفتاح الإعداد '{secret}' لتسجيل تطبيق مُصادِق TOTP. استخدم '{issuer}' لاسم الرمز و'{account}' كتسمية/اسم."

msgid "Entra Id Fido authentication failed."
msgstr "فشلت مصادقة Entra ID FIDO."

msgid "Entra Id Password:"
msgstr "كلمة مرور Entra Id:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "مصادقة FIDO غير متوفرة. يُرجى تجربة طريقة مصادقة مختلفة."

msgid "Failed to authenticate with Hello PIN."
msgstr "تعذرت المصادقة باستخدام رمز PIN الخاص بـ Hello."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "فشلت المصادقة باستخدام رقم التعريف الشخصي لـ Hello. ستؤدي محاولة فاشلة أخرى إلى طلب المصادقة متعددة العوامل وإعادة تعيين رقم التعريف الشخصي لـ Linux Hello."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "فشلت المصادقة باستخدام رمز Hello TOTP."

msgid "Failed to build regex: {error}"
msgstr "فشل إنشاء التعبير النمطي: {error}"

msgid "Failed to change user password: {msg}"
msgstr "تعذّر تغيير كلمة مرور المستخدم: {msg}"

msgid "Failed to delete CSR key"
msgstr "فشل حذف مفتاح CSR"

msgid "Failed to delete intune key"
msgstr "فشل حذف مفتاح Intune"

msgid "Failed to generate QR code"
msgstr "فشل إنشاء رمز QR"

msgid "Failed to join domain. Please contact your administrator."
msgstr "فشل الانضمام إلى المجال. يُرجى الاتصال بالمسؤول."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "فشل توفير مفتاح الترحيب: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "فشل حفظ تكوين الجهاز. يُرجى الاتصال بالمسؤول."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "فشل تخزين بيانات اعتماد الجهاز. يُرجى الاتصال بالمسؤول."

msgid "Fido PIN:"
msgstr "رمز PIN لمفتاح FIDO:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "تبدأ مصادقة Himmelblau الآن، يُرجى الانتظار..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "لم تصبح خدمة مصادقة Himmelblau متاحة في الوقت المناسب."

msgid "Himmelblau authentication service is unavailable."
msgstr "خدمة مصادقة Himmelblau غير متوفرة حاليًا."

msgid "Inputs did not match. Try again."
msgstr "المدخلات غير متطابقة. حاول مرة أخرى."

msgid "Invalid credentials"
msgstr "بيانات الاعتماد غير صالحة"

msgid "Multi-factor authentication required."
msgstr "المصادقة متعددة العوامل مطلوبة."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "المصادقة متعددة العوامل مطلوبة. يُرجى محاولة تسجيل الدخول مرة أخرى."

msgid "Network outage detected."
msgstr "تم اكتشاف انقطاع في الشبكة."

msgid "New PIN:"
msgstr "رقم التعريف الشخصي الجديد:"

msgid "New password:"
msgstr "كلمة المرور الجديدة:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "لم يتم تقديم رقم التعريف الشخصي لـ Entra ID Hello."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "لم يتم توفير رقم التعريف الشخصي لتأكيد Hello الخاص بمعرّف Entra."

msgid "No Entra Id confirmation password was supplied."
msgstr "لم يتم توفير كلمة مرور تأكيد Entra ID."

msgid "No Entra Id password was supplied."
msgstr "لم يتم تقديم كلمة مرور Entra ID."

msgid "No Hello TOTP code was supplied."
msgstr "لم يتم تقديم رمز Hello TOTP."

msgid "No input was supplied."
msgstr "لم يتم تقديم أي إدخال."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "انتهت صلاحية المصادقة دون اتصال. يُرجى الاتصال بالشبكة للمتابعة."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "افتح تطبيق Authenticator، وأدخل الرقم '{entropy}' لتسجيل الدخول."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "افتح تطبيق المصادقة وامسح رمز QR هذا للتسجيل. ثم أدخل الرمز الذي تم إنشاؤه.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "يجب ألا يستخدم رمز PIN تسلسلات متكررة أو يمكن التنبؤ بها. تجنب أنماطًا مثل '111111' أو '123456' أو '135791'."

msgid "PIN setup failed. Please try signing in again."
msgstr "فشل إعداد رقم التعريف الشخصي. يُرجى محاولة تسجيل الدخول مرة أخرى."

msgid "PIN:"
msgstr "رقم التعريف الشخصي:"

msgid "Password change required. Please contact your administrator."
msgstr "يلزم تغيير كلمة المرور. يُرجى الاتصال بالمسؤول."

msgid "Password entry required."
msgstr "إدخال كلمة المرور مطلوب."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "يلزم التسجيل لإعادة تعيين كلمة المرور. أكمل الإعداد على https://aka.ms/ssprsetup من جهاز آخر، ثم حاول مرة أخرى."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "يرجى إدخال رمز Hello TOTP من تطبيق المصادقة:"

msgid "Please insert your security key."
msgstr "يُرجى إدخال مفتاح الأمان الخاص بك."

msgid "Please select a device by touching one of them."
msgstr "يرجى تحديد جهاز بلمس أحد الأجهزة."

msgid "Please touch your security key."
msgstr "يُرجى لمس مفتاح الأمان الخاص بك."

msgid "Press enter to continue"
msgstr "اضغط على Enter للمتابعة"

msgid "QR/Bluetooth authentication failed."
msgstr "فشلت مصادقة QR/Bluetooth."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "امسح رمز QR ضوئيًا لمتابعة تسجيل الدخول، أو افتح هذا الرابط على جهاز آخر:\n"
"{complete}\n"
"إذا لم تتمكن من المسح الضوئي، فتفضل بزيارة:\n"
"{verification_uri}\n"
"وأدخل الرمز:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "امسح باستخدام تطبيق المصادقة الخاص بك"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "فشل مفتاح الأمان والمصادقة عبر رمز الاستجابة السريعة/البلوتوث."

msgid "Security key authentication failed."
msgstr "فشلت مصادقة مفتاح الأمان."

msgid "Session data corrupted. Please sign in again."
msgstr "تلفت بيانات الجلسة. يُرجى تسجيل الدخول مرة أخرى."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "قم بإعداد رقم تعريف شخصي\n"
"يُعد رقم تعريف Hello الشخصي طريقة سريعة وآمنة لتسجيل الدخول إلى جهازك وتطبيقاتك وخدماتك."

msgid "TOTP Code:"
msgstr "رمز TOTP:"

msgid "The minimum PIN length is {length} characters."
msgstr "الحد الأدنى لطول رقم التعريف الشخصي هو {length} حرفًا."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "يغير هذا الأمر رقم PIN المحلي الخاص بـ Hello، وليس كلمة مرور Entra ID الخاصة بك."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "محاولات فاشلة كثيرة جدًا على التوالي. تم حظر جهازك مؤقتًا. يُرجى فصله ثم توصيله مرة أخرى."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "حدثت محاولات فاشلة كثيرة جدًا. تم حظر جهازك. أعد تعيينه."

msgid "Too many failed user verification attempts."
msgstr "عدد محاولات التحقق من المستخدم الفاشلة كبير جدًا."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "عدد كبير جدًا من محاولات إدخال رقم التعريف الشخصي غير الصحيحة. ستحتاج إلى تسجيل رقم تعريف شخصي جديد لـ Linux Hello."

msgid "Try again."
msgstr "حاول مرة أخرى."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "خطوة مصادقة غير متوقعة. يُرجى محاولة تسجيل الدخول مرة أخرى."

msgid "Unexpected error occurred."
msgstr "حدث خطأ غير متوقع."

msgid "Unexpected error: {error}"
msgstr "خطأ غير متوقع: {error}"

msgid "Unexpected select device notice"
msgstr "إشعار غير متوقع لاختيار الجهاز"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "حدّث كلمة مرورك\n"
"تحتاج إلى تحديث كلمة مرورك لأن هذه هي\n"
"المرة الأولى التي تسجّل فيها الدخول، أو لأن\n"
"كلمة مرورك قد انتهت صلاحيتها."

msgid "Use the Linux Hello PIN for this device."
msgstr "استخدم رمز PIN الخاص بـ Linux Hello لهذا الجهاز."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "استخدم كلمة المرور الخاصة بتسجيل الدخول إلى Office 365 أو Microsoft عبر الإنترنت."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "باستخدام متصفح على جهاز آخر، تفضّل بزيارة:\n"
"{verification_uri}\n"
"ثم أدخل الرمز:\n"
"{user_code}"

msgid "Value:"
msgstr "القيمة:"

msgid "Waiting for browser authentication to complete..."
msgstr "بانتظار اكتمال المصادقة عبر المتصفح..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "لقد أرسلنا رسالة نصية إلى هاتفك {phone}. يُرجى إدخال الرمز لتسجيل الدخول:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "نتصل بهاتف مكتبك {phone}. يُرجى الرد عليه للمتابعة."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "نحن نتصل بهاتفك {phone}. يُرجى الرد للمتابعة."

msgid "Wrong PIN! {message}"
msgstr "رقم التعريف الشخصي غير صحيح! {message}"

msgid "Wrong user verification! {message}"
msgstr "فشل التحقق من المستخدم! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "لا توجد لديك {attempts} محاولات متبقية."
msgstr[1] "لديك {attempts} محاولة متبقية."
msgstr[2] "لديك {attempts} محاولتان متبقيتان."
msgstr[3] "لديك {attempts} محاولات متبقية."
msgstr[4] "لديك {attempts} محاولة متبقية."
msgstr[5] "لديك {attempts} محاولة متبقية."

msgid "Your session has expired. Please sign in again."
msgstr "انتهت صلاحية جلستك. يُرجى تسجيل الدخول مرة أخرى."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"إذا طُلبت منك الآن كلمة مرور من pam_unix، فيُرجى تجاهل المطالبة والعودة والمحاولة مرة أخرى."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"لا يوجد إشعار دفع؟ تحقّق من اتصال جهازك المحمول بالإنترنت."
