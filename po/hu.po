msgid "The minimum PIN length is {length} characters."
msgstr "A PIN-kód minimális hossza {length} karakter."

#: src/pam/src/pam/mod.rs:576
msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ez a parancs a helyi Hello PIN-kódját módosítja, NEM az Entra ID-jelszavát."

#: src/common/src/auth.rs:158
msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Túl sok sikertelen próbálkozás történt egymás után. Az eszköz ideiglenesen le lett tiltva. Kérjük, húzza ki, majd csatlakoztassa újra."

#: src/common/src/auth.rs:162
msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Túl sok sikertelen próbálkozás. Az eszköze le lett tiltva. Állítsa alaphelyzetbe."

#: src/common/src/auth.rs:181
msgid "Too many failed user verification attempts."
msgstr "Túl sok sikertelen felhasználó-ellenőrzési kísérlet történt."

#: src/common/src/idprovider/common.rs:306
msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
