msgid "An unexpected error occurred."
msgstr "Сталася неочікувана помилка."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Підтвердьте вхід у своєму застосунку автентифікації, а потім зачекайте..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Автентифікований користувач {user} не відповідає запитаному користувачу"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Автентифікований користувач {uuid} не відповідає запитаному користувачу"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Автентифікація не повернула токен оновлення. Спробуйте ще раз."

msgid "Authentication failed (AADSTS{code})"
msgstr "Автентифікація не вдалася (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Не вдалося автентифікуватися під час процесу в браузері."

msgid "Authentication failed. Please contact your administrator."
msgstr "Помилка автентифікації. Зверніться до адміністратора."

msgid "Authentication failed. Please try again."
msgstr "Не вдалося пройти автентифікацію. Спробуйте ще раз."

msgid "Authentication failed. Please try signing in again."
msgstr "Не вдалося пройти автентифікацію. Спробуйте ввійти ще раз."

msgid "Authentication failed: Authentication method not supported."
msgstr "Помилка автентифікації: метод автентифікації не підтримується."

msgid "Authentication failed: Configuration error."
msgstr "Помилка автентифікації: помилка конфігурації."

msgid "Authentication failed: Cryptographic error."
msgstr "Помилка автентифікації: криптографічна помилка."

msgid "Authentication failed: Invalid server response."
msgstr "Автентифікація не вдалася: недійсна відповідь сервера."

msgid "Authentication failed: Missing required data."
msgstr "Помилка автентифікації: відсутні обов’язкові дані."

msgid "Authentication failed: Security hardware error."
msgstr "Автентифікація не вдалася: помилка апаратного засобу безпеки."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Помилка автентифікації: не вдалося підключитися до сервера автентифікації."

msgid "Authentication failed: {error}"
msgstr "Не вдалося виконати автентифікацію: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Потік автентифікації завершено, але обмін токена не вдався. Спробуйте ще раз."

msgid "Authentication in progress."
msgstr "Триває автентифікація."

msgid "Authentication incomplete. Please try again."
msgstr "Автентифікацію не завершено. Спробуйте ще раз."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Служба автентифікації тимчасово недоступна. Повторіть спробу трохи пізніше."

msgid "Authentication service unavailable. Please try again later."
msgstr "Служба автентифікації недоступна. Спробуйте ще раз пізніше."

msgid "Authentication session corrupted. Please try again."
msgstr "Сеанс автентифікації пошкоджено. Спробуйте ще раз."

msgid "Authentication session data missing. Please try again."
msgstr "Дані сеансу автентифікації відсутні. Спробуйте ще раз."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Сеанс автентифікації повернув неочікуваний стан. Спробуйте ще раз."

msgid "Authentication timed out. Please try again."
msgstr "Час очікування автентифікації минув. Спробуйте ще раз."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Серверна частина автентифікації через браузер недоступна. Спробуйте ще раз."

msgid "Changing the password. Please wait..."
msgstr "Змінюємо пароль. Зачекайте, будь ласка..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Вибраний пароль занадто короткий! Потрібно 8 символів."

msgid "Chosen pin is too short! {length} chars required."
msgstr "Вибраний PIN-код занадто короткий! Потрібно {length} символів."

msgid "Cloud Password:"
msgstr "Хмарний пароль:"

msgid "Code:"
msgstr "Код:"

msgid "Confirm PIN:"
msgstr "Підтвердьте PIN-код:"

msgid "Confirm password:"
msgstr "Підтвердьте пароль:"

msgid "Consent required. Please contact your administrator."
msgstr "Потрібна згода. Зверніться до адміністратора."

msgid "Create a PIN to use in place of passwords."
msgstr "Створіть PIN-код, щоб використовувати його замість паролів."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Не вдалося зареєструвати пристрій. Зверніться до свого адміністратора."

msgid "Device has been removed from the domain."
msgstr "Пристрій вилучено з домену."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Увімкніть Bluetooth, щоб увійти за допомогою телефона."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Реєстрація PIN-коду Hello. Зачекайте..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Введіть ключ налаштування «{secret}», щоб зареєструвати застосунок автентифікатора TOTP. Використовуйте «{issuer}» як назву коду, а «{account}» як мітку/назву."

msgid "Entra Id Fido authentication failed."
msgstr "Не вдалося виконати автентифікацію Entra ID FIDO."

msgid "Entra Id Password:"
msgstr "Пароль Entra ID:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "Автентифікація FIDO недоступна. Спробуйте інший метод автентифікації."

msgid "Failed to authenticate with Hello PIN."
msgstr "Не вдалося пройти автентифікацію за допомогою PIN-коду Hello."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Не вдалося пройти автентифікацію за допомогою Hello PIN. Ще одна невдала спроба призведе до необхідності багатофакторної автентифікації та скидання вашого Linux Hello PIN."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Не вдалося автентифікуватися за допомогою коду Hello TOTP."

msgid "Failed to build regex: {error}"
msgstr "Не вдалося створити регулярний вираз: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Не вдалося змінити пароль користувача: {msg}"

msgid "Failed to delete CSR key"
msgstr "Не вдалося видалити ключ CSR"

msgid "Failed to delete intune key"
msgstr "Не вдалося видалити ключ Intune"

msgid "Failed to generate QR code"
msgstr "Не вдалося створити QR-код"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Не вдалося приєднатися до домену. Зверніться до адміністратора."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Не вдалося підготувати ключ Hello: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Не вдалося зберегти конфігурацію пристрою. Зверніться до адміністратора."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Не вдалося зберегти облікові дані пристрою. Зверніться до свого адміністратора."

msgid "Fido PIN:"
msgstr "PIN-код FIDO:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Автентифікація Himmelblau запускається, зачекайте..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Служба автентифікації Himmelblau не стала доступною вчасно."

msgid "Himmelblau authentication service is unavailable."
msgstr "Служба автентифікації Himmelblau недоступна."

msgid "Inputs did not match. Try again."
msgstr "Введені дані не збігаються. Спробуйте ще раз."

msgid "Invalid credentials"
msgstr "Недійсні облікові дані"

msgid "Multi-factor authentication required."
msgstr "Потрібна багатофакторна автентифікація."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Потрібна багатофакторна автентифікація. Спробуйте ввійти ще раз."

msgid "Network outage detected."
msgstr "Виявлено збій у роботі мережі."

msgid "New PIN:"
msgstr "Новий PIN-код:"

msgid "New password:"
msgstr "Новий пароль:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "PIN-код Entra ID Hello не було надано."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Не було надано PIN-код підтвердження Entra Id Hello."

msgid "No Entra Id confirmation password was supplied."
msgstr "Пароль підтвердження Entra Id не було надано."

msgid "No Entra Id password was supplied."
msgstr "Пароль Entra Id не було надано."

msgid "No Hello TOTP code was supplied."
msgstr "Не було надано TOTP-код Hello."

msgid "No input was supplied."
msgstr "Не було надано жодних вхідних даних."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Термін дії офлайн-автентифікації минув. Підключіться до мережі, щоб продовжити."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Відкрийте застосунок Authenticator і введіть число «{entropy}», щоб увійти."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Відкрийте застосунок автентифікації та відскануйте цей QR-код, щоб зареєструватися. Потім введіть згенерований код.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN-код не повинен містити повторювані або передбачувані послідовності. Уникайте шаблонів на кшталт '111111', '123456' або '135791'."

msgid "PIN setup failed. Please try signing in again."
msgstr "Не вдалося налаштувати PIN-код. Спробуйте ввійти ще раз."

msgid "PIN:"
msgstr "PIN-код:"

msgid "Password change required. Please contact your administrator."
msgstr "Потрібно змінити пароль. Зверніться до свого адміністратора."

msgid "Password entry required."
msgstr "Потрібно ввести пароль."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Потрібна реєстрація для скидання пароля. Завершіть налаштування на https://aka.ms/ssprsetup з іншого пристрою, а потім спробуйте ще раз."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Будь ласка, введіть свій код Hello TOTP з Authenticator:"

msgid "Please insert your security key."
msgstr "Будь ласка, вставте ключ безпеки."

msgid "Please select a device by touching one of them."
msgstr "Будь ласка, виберіть пристрій, торкнувшись одного з них."

msgid "Please touch your security key."
msgstr "Торкніться свого ключа безпеки."

msgid "Press enter to continue"
msgstr "Натисніть Enter, щоб продовжити"

msgid "QR/Bluetooth authentication failed."
msgstr "Не вдалося виконати автентифікацію за допомогою QR/Bluetooth."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Scan the QR code to continue signing in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Відскануйте за допомогою програми автентифікації"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Не вдалося виконати автентифікацію за допомогою ключа безпеки та QR/Bluetooth."

msgid "Security key authentication failed."
msgstr "Не вдалося виконати автентифікацію за допомогою ключа безпеки."

msgid "Session data corrupted. Please sign in again."
msgstr "Дані сеансу пошкоджено. Увійдіть знову."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps and services."

msgid "TOTP Code:"
msgstr "Код TOTP:"

msgid "The minimum PIN length is {length} characters."
msgstr "Мінімальна довжина PIN-коду — {length} символів."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ця команда змінює ваш локальний PIN-код Hello, а НЕ ваш пароль Entra Id."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Забагато невдалих спроб поспіль. Ваш пристрій тимчасово заблоковано. Від'єднайте його та підключіть знову."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Забагато невдалих спроб. Ваш пристрій заблоковано. Скиньте його налаштування."

msgid "Too many failed user verification attempts."
msgstr "Забагато невдалих спроб перевірки користувача."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Забагато неправильних спроб введення PIN-коду. Вам потрібно буде зареєструвати новий PIN-код Linux Hello."

msgid "Try again."
msgstr "Спробуйте ще раз."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Неочікуваний етап автентифікації. Спробуйте ввійти знову."

msgid "Unexpected error occurred."
msgstr "Сталася неочікувана помилка."

msgid "Unexpected error: {error}"
msgstr "Неочікувана помилка: {error}"

msgid "Unexpected select device notice"
msgstr "Неочікуване повідомлення про вибір пристрою"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Оновіть пароль\n"
"Вам потрібно оновити пароль, оскільки це\n"
"перший раз, коли ви входите в систему, або тому, що термін дії вашого\n"
"пароля завершився."

msgid "Use the Linux Hello PIN for this device."
msgstr "Використайте PIN-код Linux Hello для цього пристрою."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Використовуйте пароль для входу в Office 365 або Microsoft Online."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Використовуючи браузер на іншому пристрої, перейдіть за адресою:\n"
"{verification_uri}\n"
"І введіть код:\n"
"{user_code}"

msgid "Value:"
msgstr "Значення:"

msgid "Waiting for browser authentication to complete..."
msgstr "Очікування завершення автентифікації в браузері..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Ми надіслали SMS на ваш телефон {phone}. Введіть код, щоб увійти:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Ми телефонуємо на ваш робочий телефон {phone}. Будь ласка, прийміть дзвінок, щоб продовжити."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Ми телефонуємо вам на номер {phone}. Будь ласка, дайте відповідь, щоб продовжити."

msgid "Wrong PIN! {message}"
msgstr "Неправильний PIN-код! {message}"

msgid "Wrong user verification! {message}"
msgstr "Неправильна перевірка користувача! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "У вас залишилася {attempts} спроба."
msgstr[1] "У вас залишилося {attempts} спроби."
msgstr[2] "У вас залишилося {attempts} спроб."

msgid "Your session has expired. Please sign in again."
msgstr "Ваш сеанс завершився. Увійдіть знову."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Якщо зараз вам пропонується ввести пароль від pam_unix, проігноруйте цей запит, поверніться назад і спробуйте ще раз."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Не надійшло push-сповіщення? Перевірте підключення до інтернету на своєму мобільному пристрої."
