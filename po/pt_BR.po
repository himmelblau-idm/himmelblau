msgid "An unexpected error occurred."
msgstr "Ocorreu um erro inesperado."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Aprove a entrada no seu aplicativo autenticador e aguarde..."

msgid "Authenticated user {user} does not match requested user"
msgstr "O usuário autenticado {user} não corresponde ao usuário solicitado"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "O usuário autenticado {uuid} não corresponde ao usuário solicitado"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "A autenticação não retornou um token de atualização. Tente novamente."

msgid "Authentication failed (AADSTS{code})"
msgstr "Falha na autenticação (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Falha na autenticação no fluxo do navegador."

msgid "Authentication failed. Please contact your administrator."
msgstr "Falha na autenticação. Entre em contato com seu administrador."

msgid "Authentication failed. Please try again."
msgstr "Falha na autenticação. Tente novamente."

msgid "Authentication failed. Please try signing in again."
msgstr "Falha na autenticação. Tente entrar novamente."

msgid "Authentication failed: Authentication method not supported."
msgstr "Falha na autenticação: método de autenticação não compatível."

msgid "Authentication failed: Configuration error."
msgstr "Falha na autenticação: erro de configuração."

msgid "Authentication failed: Cryptographic error."
msgstr "Falha na autenticação: erro criptográfico."

msgid "Authentication failed: Invalid server response."
msgstr "Falha na autenticação: resposta inválida do servidor."

msgid "Authentication failed: Missing required data."
msgstr "Falha na autenticação: dados obrigatórios ausentes."

msgid "Authentication failed: Security hardware error."
msgstr "Falha na autenticação: erro no hardware de segurança."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Falha na autenticação: não foi possível acessar o servidor de autenticação."

msgid "Authentication failed: {error}"
msgstr "Falha na autenticação: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Fluxo de autenticação concluído, mas a troca de token falhou. Tente novamente."

msgid "Authentication in progress."
msgstr "Autenticação em andamento."

msgid "Authentication incomplete. Please try again."
msgstr "Autenticação incompleta. Tente novamente."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "O serviço de autenticação está temporariamente indisponível. Tente novamente em breve."

msgid "Authentication service unavailable. Please try again later."
msgstr "Serviço de autenticação indisponível. Tente novamente mais tarde."

msgid "Authentication session corrupted. Please try again."
msgstr "Sessão de autenticação corrompida. Tente novamente."

msgid "Authentication session data missing. Please try again."
msgstr "Dados da sessão de autenticação ausentes. Tente novamente."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "A sessão de autenticação retornou um estado inesperado. Tente novamente."

msgid "Authentication timed out. Please try again."
msgstr "A autenticação expirou. Tente novamente."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Backend de autenticação do navegador indisponível. Tente novamente."

msgid "Changing the password. Please wait..."
msgstr "Alterando a senha. Aguarde..."

msgid "Chosen password is too short! 8 chars required."
msgstr "A senha escolhida é muito curta! São necessários 8 caracteres."

msgid "Chosen pin is too short! {length} chars required."
msgstr "O PIN escolhido é muito curto! {length} caracteres são necessários."

msgid "Cloud Password:"
msgstr "Senha da nuvem:"

msgid "Code:"
msgstr "Código:"

msgid "Confirm PIN:"
msgstr "Confirmar PIN:"

msgid "Confirm password:"
msgstr "Confirme a senha:"

msgid "Consent required. Please contact your administrator."
msgstr "Consentimento necessário. Entre em contato com seu administrador."

msgid "Create a PIN to use in place of passwords."
msgstr "Crie um PIN para usar no lugar de senhas."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Falha ao registrar o dispositivo. Entre em contato com o administrador."

msgid "Device has been removed from the domain."
msgstr "O dispositivo foi removido do domínio."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Ative o Bluetooth para entrar com seu telefone."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Registrando o PIN do Hello. Aguarde..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Insira a chave de configuração '{secret}' para registrar um aplicativo autenticador TOTP. Use '{issuer}' como nome do código e '{account}' como rótulo/nome."

msgid "Entra Id Fido authentication failed."
msgstr "A autenticação FIDO do Entra ID falhou."

msgid "Entra Id Password:"
msgstr "Senha do Entra ID:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "Autenticação FIDO indisponível. Tente usar um método de autenticação diferente."

msgid "Failed to authenticate with Hello PIN."
msgstr "Falha ao autenticar com o PIN do Hello."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Falha ao autenticar com o PIN do Hello. Mais uma tentativa malsucedida exigirá autenticação multifator e a redefinição do seu PIN do Linux Hello."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Falha ao autenticar com o código TOTP do Hello."

msgid "Failed to build regex: {error}"
msgstr "Falha ao criar regex: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Falha ao alterar a senha do usuário: {msg}"

msgid "Failed to delete CSR key"
msgstr "Falha ao excluir a chave CSR"

msgid "Failed to delete intune key"
msgstr "Falha ao excluir a chave do Intune"

msgid "Failed to generate QR code"
msgstr "Falha ao gerar o código QR"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Falha ao ingressar no domínio. Entre em contato com o administrador."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Falha ao provisionar a chave Hello: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Falha ao salvar a configuração do dispositivo. Entre em contato com o administrador."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Falha ao armazenar as credenciais do dispositivo. Entre em contato com o administrador."

msgid "Fido PIN:"
msgstr "PIN do FIDO:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "A autenticação do Himmelblau está iniciando, aguarde..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "O serviço de autenticação Himmelblau não ficou disponível a tempo."

msgid "Himmelblau authentication service is unavailable."
msgstr "O serviço de autenticação Himmelblau está indisponível."

msgid "Inputs did not match. Try again."
msgstr "As entradas não coincidem. Tente novamente."

msgid "Invalid credentials"
msgstr "Credenciais inválidas"

msgid "Multi-factor authentication required."
msgstr "Autenticação multifator necessária."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Autenticação multifator necessária. Tente entrar novamente."

msgid "Network outage detected."
msgstr "Falha de rede detectada."

msgid "New PIN:"
msgstr "Novo PIN:"

msgid "New password:"
msgstr "Nova senha:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "Nenhum PIN do Entra ID Hello foi fornecido."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Nenhum PIN de confirmação do Hello do Entra ID foi fornecido."

msgid "No Entra Id confirmation password was supplied."
msgstr "Nenhuma senha de confirmação do Entra ID foi fornecida."

msgid "No Entra Id password was supplied."
msgstr "Nenhuma senha do Entra ID foi fornecida."

msgid "No Hello TOTP code was supplied."
msgstr "Nenhum código TOTP do Hello foi fornecido."

msgid "No input was supplied."
msgstr "Nenhuma entrada foi fornecida."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "A autenticação offline expirou. Conecte-se à rede para continuar."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Abra seu aplicativo Authenticator e insira o número '{entropy}' para entrar."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Abra seu aplicativo autenticador e escaneie este código QR para se cadastrar. Em seguida, insira o código gerado.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "O PIN não deve usar sequências repetidas ou previsíveis. Evite padrões como '111111', '123456' ou '135791'."

msgid "PIN setup failed. Please try signing in again."
msgstr "Falha na configuração do PIN. Tente entrar novamente."

msgid "PIN:"
msgstr "PIN:"

msgid "Password change required. Please contact your administrator."
msgstr "É necessário alterar a senha. Entre em contato com o administrador."

msgid "Password entry required."
msgstr "É necessário inserir a senha."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Registro de redefinição de senha necessário. Conclua a configuração em https://aka.ms/ssprsetup em outro dispositivo e tente novamente."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Insira seu código TOTP do Hello a partir do seu Autenticador:"

msgid "Please insert your security key."
msgstr "Insira sua chave de segurança."

msgid "Please select a device by touching one of them."
msgstr "Selecione um dispositivo tocando em um deles."

msgid "Please touch your security key."
msgstr "Toque na sua chave de segurança."

msgid "Press enter to continue"
msgstr "Pressione Enter para continuar"

msgid "QR/Bluetooth authentication failed."
msgstr "A autenticação por QR/Bluetooth falhou."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Leia o código QR para continuar o login ou abra este link em outro dispositivo:\n"
"{complete}\n"
"Se não conseguir ler o código, acesse:\n"
"{verification_uri}\n"
"E insira o código:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Escaneie com seu aplicativo autenticador"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Falha na autenticação por chave de segurança e QR/Bluetooth."

msgid "Security key authentication failed."
msgstr "Falha na autenticação com chave de segurança."

msgid "Session data corrupted. Please sign in again."
msgstr "Dados da sessão corrompidos. Entre novamente."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Configure um PIN\n"
"Um PIN do Hello é uma forma rápida e segura de entrar no seu dispositivo, aplicativos e serviços."

msgid "TOTP Code:"
msgstr "Código TOTP:"

msgid "The minimum PIN length is {length} characters."
msgstr "O comprimento mínimo do PIN é de {length} caracteres."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Este comando altera seu PIN local do Hello, NÃO sua senha do Entra ID."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Muitas tentativas malsucedidas consecutivas. Seu dispositivo foi bloqueado temporariamente. Desconecte-o e conecte-o novamente."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Muitas tentativas falhas. Seu dispositivo foi bloqueado. Redefina-o."

msgid "Too many failed user verification attempts."
msgstr "Muitas tentativas de verificação do usuário falharam."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Muitas tentativas incorretas de PIN. Você precisará cadastrar um novo PIN do Linux Hello."

msgid "Try again."
msgstr "Tente novamente."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Etapa de autenticação inesperada. Tente entrar novamente."

msgid "Unexpected error occurred."
msgstr "Ocorreu um erro inesperado."

msgid "Unexpected error: {error}"
msgstr "Erro inesperado: {error}"

msgid "Unexpected select device notice"
msgstr "Aviso inesperado de seleção de dispositivo"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Atualize sua senha\n"
"Você precisa atualizar sua senha porque este é\n"
"o primeiro acesso ou porque sua senha\n"
"expirou."

msgid "Use the Linux Hello PIN for this device."
msgstr "Use o PIN do Linux Hello para este dispositivo."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Use a senha do seu login do Office 365 ou da Microsoft online."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Usando um navegador em outro dispositivo, acesse:\n"
"{verification_uri}\n"
"E insira o código:\n"
"{user_code}"

msgid "Value:"
msgstr "Valor:"

msgid "Waiting for browser authentication to complete..."
msgstr "Aguardando a conclusão da autenticação no navegador..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Enviamos uma mensagem de texto para o seu telefone {phone}. Insira o código para entrar:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Estamos ligando para o telefone do seu escritório {phone}. Atenda para continuar."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Estamos ligando para o seu telefone {phone}. Atenda para continuar."

msgid "Wrong PIN! {message}"
msgstr "PIN incorreto! {message}"

msgid "Wrong user verification! {message}"
msgstr "Verificação do usuário incorreta! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Você tem {attempts} tentativa restante."
msgstr[1] "Você tem {attempts} tentativas restantes."

msgid "Your session has expired. Please sign in again."
msgstr "Sua sessão expirou. Entre novamente."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Se agora for solicitada uma senha pelo pam_unix, ignore a solicitação, volte e tente novamente."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Não recebeu a notificação por push? Verifique a conexão com a internet do seu dispositivo móvel."
