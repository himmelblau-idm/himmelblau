msgid "An unexpected error occurred."
msgstr "Įvyko netikėta klaida."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Patvirtinkite prisijungimą autentifikavimo programėlėje, tada palaukite..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Autentifikuotas naudotojas {user} neatitinka prašomo naudotojo"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Autentifikuotas naudotojas {uuid} neatitinka prašomo naudotojo"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Autentifikavimas negrąžino atnaujinimo prieigos rakto. Bandykite dar kartą."

msgid "Authentication failed (AADSTS{code})"
msgstr "Autentifikavimas nepavyko (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Autentifikavimas naršyklės sraute nepavyko."

msgid "Authentication failed. Please contact your administrator."
msgstr "Autentifikavimas nepavyko. Kreipkitės į administratorių."

msgid "Authentication failed. Please try again."
msgstr "Autentifikavimas nepavyko. Bandykite dar kartą."

msgid "Authentication failed. Please try signing in again."
msgstr "Autentifikavimas nepavyko. Bandykite prisijungti dar kartą."

msgid "Authentication failed: Authentication method not supported."
msgstr "Autentifikacija nepavyko: autentifikavimo metodas nepalaikomas."

msgid "Authentication failed: Configuration error."
msgstr "Autentifikacija nepavyko: konfigūracijos klaida."

msgid "Authentication failed: Cryptographic error."
msgstr "Autentifikavimas nepavyko: kriptografinė klaida."

msgid "Authentication failed: Invalid server response."
msgstr "Autentifikavimas nepavyko: neteisingas serverio atsakymas."

msgid "Authentication failed: Missing required data."
msgstr "Autentifikavimas nepavyko: trūksta būtinų duomenų."

msgid "Authentication failed: Security hardware error."
msgstr "Autentifikavimas nepavyko: saugos aparatinės įrangos klaida."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Autentifikavimas nepavyko: nepavyko pasiekti autentifikavimo serverio."

msgid "Authentication failed: {error}"
msgstr "Autentifikavimas nepavyko: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Autentifikavimo procesas baigtas, tačiau nepavyko apsikeisti prieigos raktu. Bandykite dar kartą."

msgid "Authentication in progress."
msgstr "Autentifikavimas vykdomas."

msgid "Authentication incomplete. Please try again."
msgstr "Autentifikavimas nebaigtas. Bandykite dar kartą."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Autentifikavimo paslauga laikinai nepasiekiama. Bandykite dar kartą netrukus."

msgid "Authentication service unavailable. Please try again later."
msgstr "Autentifikavimo paslauga nepasiekiama. Bandykite dar kartą vėliau."

msgid "Authentication session corrupted. Please try again."
msgstr "Autentifikavimo seansas sugadintas. Bandykite dar kartą."

msgid "Authentication session data missing. Please try again."
msgstr "Trūksta autentifikavimo seanso duomenų. Bandykite dar kartą."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Autentifikavimo seansas grąžino netikėtą būseną. Bandykite dar kartą."

msgid "Authentication timed out. Please try again."
msgstr "Autentifikavimo laikas baigėsi. Bandykite dar kartą."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Naršyklės autentifikavimo posistemė nepasiekiama. Bandykite dar kartą."

msgid "Changing the password. Please wait..."
msgstr "Keičiamas slaptažodis. Palaukite..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Pasirinktas slaptažodis per trumpas! Reikia 8 simbolių."

msgid "Chosen pin is too short! {length} chars required."
msgstr "Pasirinktas PIN kodas per trumpas! Reikia {length} simb."

msgid "Cloud Password:"
msgstr "Debesijos slaptažodis:"

msgid "Code:"
msgstr "Kodas:"

msgid "Confirm PIN:"
msgstr "Patvirtinkite PIN kodą:"

msgid "Confirm password:"
msgstr "Patvirtinkite slaptažodį:"

msgid "Consent required. Please contact your administrator."
msgstr "Reikalingas sutikimas. Susisiekite su savo administratoriumi."

msgid "Create a PIN to use in place of passwords."
msgstr "Sukurkite PIN kodą, kurį naudosite vietoje slaptažodžių."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Nepavyko užregistruoti įrenginio. Susisiekite su administratoriumi."

msgid "Device has been removed from the domain."
msgstr "Įrenginys pašalintas iš domeno."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Įjunkite „Bluetooth“, kad prisijungtumėte naudodami telefoną."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Registruojamas „Hello“ PIN kodas. Palaukite..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Įveskite sąrankos raktą „{secret}“, kad užregistruotumėte TOTP autentifikavimo programėlę. Kodo pavadinimui naudokite „{issuer}“, o etiketei / vardui – „{account}“."

msgid "Entra Id Fido authentication failed."
msgstr "Nepavyko atlikti Entra ID FIDO autentifikavimo."

msgid "Entra Id Password:"
msgstr "Entra ID slaptažodis:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "FIDO autentifikavimas nepasiekiamas. Bandykite naudoti kitą autentifikavimo metodą."

msgid "Failed to authenticate with Hello PIN."
msgstr "Nepavyko autentifikuoti naudojant „Hello“ PIN kodą."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Nepavyko autentifikuoti naudojant „Hello“ PIN kodą. Po dar vieno nesėkmingo bandymo reikės atlikti kelių veiksnių autentifikavimą ir iš naujo nustatyti jūsų „Linux Hello“ PIN kodą."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Nepavyko autentifikuoti naudojant Hello TOTP kodą."

msgid "Failed to build regex: {error}"
msgstr "Nepavyko sukurti reguliariosios išraiškos: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Nepavyko pakeisti naudotojo slaptažodžio: {msg}"

msgid "Failed to delete CSR key"
msgstr "Nepavyko panaikinti CSR rakto"

msgid "Failed to delete intune key"
msgstr "Nepavyko ištrinti „Intune“ rakto"

msgid "Failed to generate QR code"
msgstr "Nepavyko sugeneruoti QR kodo"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Nepavyko prisijungti prie domeno. Susisiekite su administratoriumi."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Nepavyko parengti „Hello“ rakto: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Nepavyko išsaugoti įrenginio konfigūracijos. Kreipkitės į savo administratorių."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Nepavyko išsaugoti įrenginio kredencialų. Susisiekite su administratoriumi."

msgid "Fido PIN:"
msgstr "FIDO PIN kodas:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Pradedamas Himmelblau autentifikavimas, palaukite..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "„Himmelblau“ autentifikavimo paslauga laiku netapo pasiekiama."

msgid "Himmelblau authentication service is unavailable."
msgstr "Himmelblau autentifikavimo paslauga nepasiekiama."

msgid "Inputs did not match. Try again."
msgstr "Įvestys nesutapo. Bandykite dar kartą."

msgid "Invalid credentials"
msgstr "Neteisingi prisijungimo duomenys"

msgid "Multi-factor authentication required."
msgstr "Reikalingas kelių veiksnių autentifikavimas."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Reikalingas kelių veiksnių autentifikavimas. Bandykite prisijungti dar kartą."

msgid "Network outage detected."
msgstr "Aptiktas tinklo sutrikimas."

msgid "New PIN:"
msgstr "Naujas PIN kodas:"

msgid "New password:"
msgstr "Naujas slaptažodis:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "Nepateiktas „Entra ID Hello“ PIN kodas."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "Nepateiktas „Entra ID Hello“ patvirtinimo PIN kodas."

msgid "No Entra Id confirmation password was supplied."
msgstr "Nepateiktas „Entra ID“ patvirtinimo slaptažodis."

msgid "No Entra Id password was supplied."
msgstr "„Entra ID“ slaptažodis nebuvo pateiktas."

msgid "No Hello TOTP code was supplied."
msgstr "Nepateiktas „Hello“ TOTP kodas."

msgid "No input was supplied."
msgstr "Nepateikta jokia įvestis."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Baigėsi autentifikavimo neprisijungus galiojimas. Norėdami tęsti, prisijunkite prie tinklo."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Atidarykite savo „Authenticator“ programėlę ir įveskite skaičių „{entropy}“, kad prisijungtumėte."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Atidarykite autentifikavimo programą ir nuskaitykite šį QR kodą, kad užsiregistruotumėte. Tada įveskite sugeneruotą kodą.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN negali naudoti pasikartojančių ar nuspėjamų sekų. Venkite tokių šablonų kaip „111111“, „123456“ ar „135791“."

msgid "PIN setup failed. Please try signing in again."
msgstr "PIN kodo nustatyti nepavyko. Bandykite prisijungti dar kartą."

msgid "PIN:"
msgstr "PIN kodas:"

msgid "Password change required. Please contact your administrator."
msgstr "Reikia pakeisti slaptažodį. Susisiekite su administratoriumi."

msgid "Password entry required."
msgstr "Reikia įvesti slaptažodį."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Būtina užsiregistruoti slaptažodžio nustatymui iš naujo. Užbaikite sąranką adresu https://aka.ms/ssprsetup iš kito įrenginio, tada bandykite dar kartą."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Įveskite savo „Hello“ TOTP kodą iš autentifikavimo programėlės:"

msgid "Please insert your security key."
msgstr "Įdėkite saugos raktą."

msgid "Please select a device by touching one of them."
msgstr "Pasirinkite įrenginį paliesdami vieną iš jų."

msgid "Please touch your security key."
msgstr "Palieskite savo saugos raktą."

msgid "Press enter to continue"
msgstr "Norėdami tęsti, paspauskite Enter"

msgid "QR/Bluetooth authentication failed."
msgstr "QR / „Bluetooth“ autentifikavimas nepavyko."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Nuskaitykite QR kodą, kad tęstumėte prisijungimą, arba atidarykite šią nuorodą kitame įrenginyje:\n"
"{complete}\n"
"Jei negalite nuskaityti, apsilankykite:\n"
"{verification_uri}\n"
"Ir įveskite kodą:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Nuskaitykite naudodami savo autentifikavimo programą"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Saugos rakto ir QR/Bluetooth autentifikavimas nepavyko."

msgid "Security key authentication failed."
msgstr "Saugos rakto autentifikavimas nepavyko."

msgid "Session data corrupted. Please sign in again."
msgstr "Seanso duomenys sugadinti. Prisijunkite dar kartą."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "Nustatykite PIN kodą\n"
"„Hello“ PIN kodas yra greitas ir saugus būdas prisijungti prie įrenginio, programėlių ir paslaugų."

msgid "TOTP Code:"
msgstr "TOTP kodas:"

msgid "The minimum PIN length is {length} characters."
msgstr "Minimalus PIN kodo ilgis yra {length} simbolių."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ši komanda pakeičia jūsų vietinį „Hello“ PIN kodą, o NE jūsų „Entra ID“ slaptažodį."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Per daug nesėkmingų bandymų iš eilės. Jūsų įrenginys laikinai užblokuotas. Atjunkite jį ir vėl prijunkite."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Per daug nesėkmingų bandymų. Jūsų įrenginys užblokuotas. Nustatykite jį iš naujo."

msgid "Too many failed user verification attempts."
msgstr "Per daug nepavykusių naudotojo patvirtinimo bandymų."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Per daug neteisingų PIN kodo bandymų. Turėsite užregistruoti naują „Linux Hello“ PIN kodą."

msgid "Try again."
msgstr "Bandykite dar kartą."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Netikėtas autentifikavimo veiksmas. Bandykite prisijungti dar kartą."

msgid "Unexpected error occurred."
msgstr "Įvyko netikėta klaida."

msgid "Unexpected error: {error}"
msgstr "Netikėta klaida: {error}"

msgid "Unexpected select device notice"
msgstr "Netikėtas įrenginio pasirinkimo pranešimas"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Atnaujinkite slaptažodį\n"
"Turite atnaujinti slaptažodį, nes prisijungiate\n"
"pirmą kartą arba baigėsi jūsų slaptažodžio\n"
"galiojimo laikas."

msgid "Use the Linux Hello PIN for this device."
msgstr "Naudokite šio įrenginio „Linux Hello“ PIN kodą."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Naudokite savo „Office 365“ arba „Microsoft“ internetinio prisijungimo slaptažodį."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Naudodami naršyklę kitame įrenginyje, apsilankykite adresu:\n"
"{verification_uri}\n"
"Ir įveskite kodą:\n"
"{user_code}"

msgid "Value:"
msgstr "Reikšmė:"

msgid "Waiting for browser authentication to complete..."
msgstr "Laukiama, kol bus baigtas autentifikavimas naršyklėje..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Išsiuntėme SMS žinutę į jūsų telefoną {phone}. Įveskite kodą, kad prisijungtumėte:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Skambiname jūsų darbo telefonu {phone}. Atsiliepkite, kad galėtumėte tęsti."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Skambiname į jūsų telefoną {phone}. Atsiliepkite, kad galėtumėte tęsti."

msgid "Wrong PIN! {message}"
msgstr "Neteisingas PIN kodas! {message}"

msgid "Wrong user verification! {message}"
msgstr "Neteisingas naudotojo patvirtinimas! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Jums liko {attempts} bandymas."
msgstr[1] "Jums liko {attempts} bandymai."
msgstr[2] "Jums liko {attempts} bandymų."

msgid "Your session has expired. Please sign in again."
msgstr "Jūsų seansas baigėsi. Prisijunkite dar kartą."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Jei dabar pam_unix paragins įvesti slaptažodį, nepaisykite šio raginimo, grįžkite atgal ir bandykite dar kartą."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Negavote pranešimo? Patikrinkite savo mobiliojo įrenginio interneto ryšį."
