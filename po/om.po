msgid "An unexpected error occurred."
msgstr "Dogoggorri hin eegamne uumame."

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "Appii mirkaneessaa keessan keessatti seensa mirkaneessaa, sana booda eegaa..."

msgid "Authenticated user {user} does not match requested user"
msgstr "Fayyadamaan mirkanaa'e {user} fayyadamaa gaafatame waliin wal hin simu"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "Fayyadamaan mirkanaa'e {uuid} fayyadamaa gaafatame waliin wal hin simu"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "Mirkaneessi eenyummaa refresh token hin deebisne. Maaloo irra deebi'ii yaali."

msgid "Authentication failed (AADSTS{code})"
msgstr "Mirkaneessuun eenyummaa hin milkoofne (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "Adeemsa biraawzarii keessatti mirkaneessuun eenyummaa hin milkoofne."

msgid "Authentication failed. Please contact your administrator."
msgstr "Mirkaneessuun hin milkoofne. Maaloo bulchaa keessan qunnamaa."

msgid "Authentication failed. Please try again."
msgstr "Mirkaneessuun hin milkoofne. Maaloo irra deebi'ii yaali."

msgid "Authentication failed. Please try signing in again."
msgstr "Mirkaneessuun hin milkoofne. Maaloo irra deebi'ii seeni."

msgid "Authentication failed: Authentication method not supported."
msgstr "Mirkaneessuun fashalaa'e: Malli mirkaneessaa hin deeggaramu."

msgid "Authentication failed: Configuration error."
msgstr "Mirkaneessi eenyummaa hin milkoofne: Dogoggora qindaa'inaa."

msgid "Authentication failed: Cryptographic error."
msgstr "Mirkaneessi hin milkoofne: Dogoggora kirpitoogiraafii."

msgid "Authentication failed: Invalid server response."
msgstr "Mirkaneessi eenyummaa hin milkoofne: Deebiin sarvaraa sirrii miti."

msgid "Authentication failed: Missing required data."
msgstr "Mirkaneessuun hin milkoofne: Odeeffannoon barbaachisu hin jiru."

msgid "Authentication failed: Security hardware error."
msgstr "Mirkaneessi eenyummaa hin milkoofne: Dogoggora meeshaa nageenyaa."

msgid "Authentication failed: Unable to reach authentication server."
msgstr "Mirkaneessi eenyummaa hin milkoofne: Sarvarii mirkaneessa eenyummaa bira ga'uu hin dandeenye."

msgid "Authentication failed: {error}"
msgstr "Mirkaneessi eenyummaa hin milkoofne: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "Adeemsi mirkaneessuu xumurameera garuu jijjiirraan tookenii hin milkoofne. Mee irra deebi'ii yaali."

msgid "Authentication in progress."
msgstr "Mirkaneessi eenyummaa adeemsarra jira."

msgid "Authentication incomplete. Please try again."
msgstr "Mirkaneessuun eenyummaa hin xumuramne. Maaloo irra deebi'ii yaali."

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "Tajaajilli mirkaneessa eenyummaa yeroo muraasaaf hin argamu. Maaloo yeroo gabaabaa booda irra deebi'aa yaalaa."

msgid "Authentication service unavailable. Please try again later."
msgstr "Tajaajilli mirkaneessa eenyummaa hin argamu. Maaloo booda irra deebi'ii yaali."

msgid "Authentication session corrupted. Please try again."
msgstr "Turtiin mirkaneessa eenyummaa manca'eera. Maaloo irra deebi'ii yaali."

msgid "Authentication session data missing. Please try again."
msgstr "Daataa tursa mirkaneessaa hin jiru. Irra deebi'ii yaali."

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "Kutaan mirkaneessaa haala hin eegamne deebise. Mee irra deebi'ii yaali."

msgid "Authentication timed out. Please try again."
msgstr "Mirkaneessuun galuun yeroon isaa darbe. Irra deebi'ii yaali."

msgid "Browser authentication backend unavailable. Please try again."
msgstr "Backend mirkaneessa eenyummaa biraawzaraa hin argamne. Maaloo irra deebi'ii yaali."

msgid "Changing the password. Please wait..."
msgstr "Jecha darbii jijjiiraa jira. Maaloo eegaa..."

msgid "Chosen password is too short! 8 chars required."
msgstr "Jechi darbii filatame baay'ee gabaabaadha! Arfiileen 8 barbaachisu."

msgid "Chosen pin is too short! {length} chars required."
msgstr "PIN filatame baay'ee gabaabaa dha! Arfiilee {length} barbaachisu."

msgid "Cloud Password:"
msgstr "Jecha Darbii Duumessaa:"

msgid "Code:"
msgstr "Koodii:"

msgid "Confirm PIN:"
msgstr "PIN mirkaneessi:"

msgid "Confirm password:"
msgstr "Mirkaneessa mirkaneessi:"

msgid "Consent required. Please contact your administrator."
msgstr "Hayyamni barbaachisa. Maaloo bulchaa kee qunnami."

msgid "Create a PIN to use in place of passwords."
msgstr "Jecha darbiiwwan bakka buusuuf PIN uumi."

msgid "Device enrollment failed. Please contact your administrator."
msgstr "Galmeen meeshaa hin milkoofne. Maaloo bulchaa keessan quunnamaa."

msgid "Device has been removed from the domain."
msgstr "Meeshaan kun doomeenii irraa haqameera."

msgid "Enable Bluetooth to sign in with your phone."
msgstr "Bilbila keetiin seenuuf Bluetooth bani."

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Hello PIN galmeessaa jira. Maaloo eegaa..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "Appii Mirkaneessaa TOTP galmeessuuf furtuu qindeessaa '{secret}' galchi. Maqaa koodii taasisuun '{issuer}' fayyadami, asxaa/maqaa immoo '{account}' fayyadami."

msgid "Entra Id Fido authentication failed."
msgstr "Mirkaneessi Entra Id Fido hin milkoofne."

msgid "Entra Id Password:"
msgstr "Jecha iccitii Entra ID:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "Mirkaneessi FIDO hin jiru. Maaloo mala mirkaneessaa kan biraa yaali."

msgid "Failed to authenticate with Hello PIN."
msgstr "PIN Hello tiin mirkaneessuun hin milkoofne."

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "PIN Hello tiin mirkaneessuun hin milkoofne. Yaalii dabalataa tokko yoo dogoggorte, mirkaneessa wantoota hedduu fi PIN Linux Hello kee irra deebi'anii qindeessuun ni barbaachisa."

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Koodii Hello TOTP tiin mirkaneessuun hin milkoofne."

msgid "Failed to build regex: {error}"
msgstr "Regex ijaaruu hin dandeenye: {error}"

msgid "Failed to change user password: {msg}"
msgstr "Jecha icciitii fayyadamaa jijjiiruu hin milkoofne: {msg}"

msgid "Failed to delete CSR key"
msgstr "Furtuu CSR haquun hin milkoofne"

msgid "Failed to delete intune key"
msgstr "Furtuu Intune haquun hin milkoofne"

msgid "Failed to generate QR code"
msgstr "Koodii QR uumuu hin dandeenye"

msgid "Failed to join domain. Please contact your administrator."
msgstr "Domeenitti makamuun hin milkoofne. Maaloo bulchaa kee qunnamii."

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "Furtuu hello qopheessuun hin milkoofne: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "Qindaa'ina meeshaa olkaa'uun hin milkoofne. Maaloo bulchaa keessan quunnamaa."

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "Ragaa mirkaneessaa meeshaa kuusuun hin milkoofne. Maaloo bulchaa keessan qunnamaa."

msgid "Fido PIN:"
msgstr "PIN Fido:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Mirkaneessuun Himmelblau jalqabaa jira, maaloo eegaa..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Tajaajilli mirkaneessa eenyummaa Himmelblau yeroo eegame keessatti hin argamne."

msgid "Himmelblau authentication service is unavailable."
msgstr "Tajaajilli mirkaneessa eenyummaa Himmelblau hin argamu."

msgid "Inputs did not match. Try again."
msgstr "Galteewwan wal hin simne. Irra deebi'ii yaali."

msgid "Invalid credentials"
msgstr "Ragaa seensaa sirrii miti"

msgid "Multi-factor authentication required."
msgstr "Mirkaneessi saboota hedduu barbaachisa."

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "Mirkaneessi eenyummaa wantoota hedduun barbaachisa. Maaloo irra deebi'ii seenuuf yaali."

msgid "Network outage detected."
msgstr "Addaan cituun neetworkii argameera."

msgid "New PIN:"
msgstr "PIN haaraa:"

msgid "New password:"
msgstr "Jecha haaraa:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "PIN Entra Id Hello hin kennamne."

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "PIN mirkaneessaa Entra Id Hello hin kennamne."

msgid "No Entra Id confirmation password was supplied."
msgstr "Jechi icciitii mirkaneessaa Entra Id hin kennamne."

msgid "No Entra Id password was supplied."
msgstr "Jechi darbii Entra ID hin kennamne."

msgid "No Hello TOTP code was supplied."
msgstr "Koodiin Hello TOTP hin dhiyaanne."

msgid "No input was supplied."
msgstr "Galchi hin dhiyaanne."

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "Mirkaneessi sarara alaa yeroon isaa darbeera. Itti fufuuf maaloo neetworkii waliin wal qunnami."

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "Appii Authenticator kee bani, lakkoofsa '{entropy}' galchiitii seeni."

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "Appii mirkaneessaa kee baniitii galmaa’uuf koodii QR kana sakatta’i. Sana booda koodii uumame galchi.\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN tartiiba irra deddeebi'amu yookaan tilmaamamuu danda'u fayyadamuu hin qabu. Akka '111111', '123456', yookaan '135791' fakkaatan irraa fagaadhaa."

msgid "PIN setup failed. Please try signing in again."
msgstr "Qindeessuun PIN hin milkoofne. Maaloo deebi'ii seenuu yaali."

msgid "PIN:"
msgstr "PIN:"

msgid "Password change required. Please contact your administrator."
msgstr "Jecha icciitii jijjiiruun ni barbaachisa. Maaloo bulchaa keessan quunnamaa."

msgid "Password entry required."
msgstr "Jecha icciitii galchuun barbaachisaadha."

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "Galmeen jecha darbii deebisanii saaguu barbaachisa. Qindaa'ina https://aka.ms/ssprsetup meeshaa biraa irraa xumuri, sana booda irra deebi'ii yaali."

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "Maaloo koodii Hello TOTP kee Authenticator kee irraa galchi:"

msgid "Please insert your security key."
msgstr "Mee furtuu nageenya keessanii galchaa."

msgid "Please select a device by touching one of them."
msgstr "Maaloo meeshaalee keessaa tokko tuquudhaan filadhu."

msgid "Please touch your security key."
msgstr "Maaloo furtuu nageenyaa keessan tuqaa."

msgid "Press enter to continue"
msgstr "Itti fufuuf Enter cuqaasi"

msgid "QR/Bluetooth authentication failed."
msgstr "Mirkaneessuun QR/Bluetooth hin milkoofne."

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Mallattoo QR sakatta’iitii seensa itti fufi, yookaan hidhaa kana meeshaa biraa irratti bani:\n"
"{complete}\n"
"Yoo sakatta’uu hin dandeenye, daawwadhu:\n"
"{verification_uri}\n"
"Akkasumas koodii kana galchi:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "Appii mirkaneessaa keetiin sakatta'i"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "Furtuun nageenyaa fi mirkaneessuun QR/Bluetooth hin milkoofne."

msgid "Security key authentication failed."
msgstr "Mirkaneessi furtuu nageenyaa hin milkoofne."

msgid "Session data corrupted. Please sign in again."
msgstr "Deetaan turtii miidhameera. Mee irra deebi'ii seeni."

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "PIN qopheessi\n"
"PIN Hello mala saffisaa fi nageenya qabu kan meeshaa kee, appoota, fi tajaajiloota seenuuf gargaarudha."

msgid "TOTP Code:"
msgstr "Koodii TOTP:"

msgid "The minimum PIN length is {length} characters."
msgstr "Dheerinni PIN xiqqaan {length} arfiilee dha."

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "Ajajni kun PIN Hello naannoo keetii jijjiira, jecha darbii Entra Id kee MITI."

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "Yaliiwwan kufan walitti aanan baayʼataniiru. Meeshaan kee yeroo muraasaaf uggurameera. Maaloo, baasii deebisii galchi."

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "Yaaliin hin milkoofne baay’ateera. Meeshaan kee uggurameera. Irra deebi’ii qindeessi."

msgid "Too many failed user verification attempts."
msgstr "Yaalii mirkaneeffannaa fayyadamaa baay'een fashalaa'e."

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "Yaalii PIN dogoggoraa baay'ee gootaniittu. PIN Linux Hello haaraa galmeessuu isin barbaachisa."

msgid "Try again."
msgstr "Irra deebi'ii yaali."

msgid "Unexpected authentication step. Please try signing in again."
msgstr "Tarkaanfiin mirkaneessa eenyummaa hin eegamne mudate. Maaloo deebi'ii seeni."

msgid "Unexpected error occurred."
msgstr "Dogoggorri hin eegamne uumame."

msgid "Unexpected error: {error}"
msgstr "Dogoggora hin eegamne: {error}"

msgid "Unexpected select device notice"
msgstr "Beeksisa meeshaa filachuu hin eegamne"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "Jecha darbii kee haaromsi\n"
"Jecha darbii kee haaromsuu qabda sababni isaas kun\n"
"yeroo jalqabaa itti seenaa jirtu waan ta'eef, yookaan\n"
"jechi darbii kee yeroon isaa waan darbeef."

msgid "Use the Linux Hello PIN for this device."
msgstr "PIN Linux Hello meeshaa kanaaf fayyadami."

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "Jecha icciitii seensa Office 365 ykn Microsoft onlaayinii keetii fayyadami."

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "Meesha biraawzarii meeshaa biraa irratti fayyadamuun, daawwadhu:\n"
"{verification_uri}\n"
"Koodii kana galchi:\n"
"{user_code}"

msgid "Value:"
msgstr "Gatii:"

msgid "Waiting for browser authentication to complete..."
msgstr "Mirkaneeffannaan braawzaraa akka xumuramu eegaa jira..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "Bilbila keessan {phone} irratti ergaa gabaabaa isiniif ergine. Galuu varten koodii galchaa:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "Bilbila waajjira keessan {phone} irratti isin bilbilaa jirra. Itti fufuuf maaloo deebisaa."

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "Bilbila keessan {phone} irratti bilbilaa jirra. Itti fufuuf maaloo deebisaa."

msgid "Wrong PIN! {message}"
msgstr "PIN dogoggora! {message}"

msgid "Wrong user verification! {message}"
msgstr "Mirkaneessi fayyadamaa sirrii miti! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "Yaalii {attempts} hafe qabda."
msgstr[1] "Yaaliiwwan {attempts} hafan qabda."

msgid "Your session has expired. Please sign in again."
msgstr "Turtiin keessan yeroon isaa dhumeera. Maaloo irra deebi'aa seenaa."

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"Amma jecha icciitii pam_unix irraa akka galchitan yoo gaafattamtan, maaloo gaafii sana bira darbaa, duubatti deebi'aatii irra deebi'aa yaalaa."

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"Dhiibbaa hin argannee? Walitti hidhamiinsa interneetii meeshaa moobaayilaa keessanii mirkaneessaa."
