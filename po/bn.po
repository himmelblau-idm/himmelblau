msgid "An unexpected error occurred."
msgstr "একটি অপ্রত্যাশিত ত্রুটি ঘটেছে।"

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "আপনার প্রমাণীকরণকারী অ্যাপে সাইন-ইন অনুমোদন করুন, তারপর অপেক্ষা করুন..."

msgid "Authenticated user {user} does not match requested user"
msgstr "প্রমাণীকৃত ব্যবহারকারী {user} অনুরোধ করা ব্যবহারকারীর সাথে মেলে না"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "প্রমাণীকৃত ব্যবহারকারী {uuid} অনুরোধ করা ব্যবহারকারীর সাথে মেলে না"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "প্রমাণীকরণ একটি রিফ্রেশ টোকেন ফেরত দেয়নি। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication failed (AADSTS{code})"
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "ব্রাউজার প্রবাহে প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Authentication failed. Please contact your administrator."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে। অনুগ্রহ করে আপনার প্রশাসকের সঙ্গে যোগাযোগ করুন।"

msgid "Authentication failed. Please try again."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication failed. Please try signing in again."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে। অনুগ্রহ করে আবার সাইন ইন করার চেষ্টা করুন।"

msgid "Authentication failed: Authentication method not supported."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: প্রমাণীকরণ পদ্ধতি সমর্থিত নয়।"

msgid "Authentication failed: Configuration error."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: কনফিগারেশন ত্রুটি।"

msgid "Authentication failed: Cryptographic error."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: ক্রিপ্টোগ্রাফিক ত্রুটি।"

msgid "Authentication failed: Invalid server response."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: সার্ভারের প্রতিক্রিয়া অবৈধ।"

msgid "Authentication failed: Missing required data."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: প্রয়োজনীয় ডেটা অনুপস্থিত।"

msgid "Authentication failed: Security hardware error."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: নিরাপত্তা হার্ডওয়্যার ত্রুটি।"

msgid "Authentication failed: Unable to reach authentication server."
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: প্রমাণীকরণ সার্ভারে পৌঁছানো যায়নি।"

msgid "Authentication failed: {error}"
msgstr "প্রমাণীকরণ ব্যর্থ হয়েছে: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "প্রমাণীকরণ প্রক্রিয়া সম্পন্ন হয়েছে, কিন্তু টোকেন বিনিময় ব্যর্থ হয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication in progress."
msgstr "প্রমাণীকরণ চলছে।"

msgid "Authentication incomplete. Please try again."
msgstr "প্রমাণীকরণ অসম্পূর্ণ। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "প্রমাণীকরণ পরিষেবা সাময়িকভাবে উপলভ্য নয়। অনুগ্রহ করে কিছুক্ষণ পরে আবার চেষ্টা করুন।"

msgid "Authentication service unavailable. Please try again later."
msgstr "প্রমাণীকরণ পরিষেবা উপলব্ধ নেই। অনুগ্রহ করে পরে আবার চেষ্টা করুন।"

msgid "Authentication session corrupted. Please try again."
msgstr "প্রমাণীকরণ সেশন ক্ষতিগ্রস্ত হয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication session data missing. Please try again."
msgstr "প্রমাণীকরণ সেশনের ডেটা অনুপস্থিত। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "প্রমাণীকরণ সেশনটি একটি অপ্রত্যাশিত অবস্থা ফিরিয়েছে। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Authentication timed out. Please try again."
msgstr "প্রমাণীকরণের সময় শেষ হয়ে গেছে। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Browser authentication backend unavailable. Please try again."
msgstr "ব্রাউজার প্রমাণীকরণ ব্যাকএন্ড উপলব্ধ নেই। অনুগ্রহ করে আবার চেষ্টা করুন।"

msgid "Changing the password. Please wait..."
msgstr "পাসওয়ার্ড পরিবর্তন করা হচ্ছে। অনুগ্রহ করে অপেক্ষা করুন..."

msgid "Chosen password is too short! 8 chars required."
msgstr "নির্বাচিত পাসওয়ার্ডটি খুব ছোট! ৮টি অক্ষর প্রয়োজন।"

msgid "Chosen pin is too short! {length} chars required."
msgstr "নির্বাচিত পিনটি খুব ছোট! {length}টি অক্ষর প্রয়োজন।"

msgid "Cloud Password:"
msgstr "ক্লাউড পাসওয়ার্ড:"

msgid "Code:"
msgstr "কোড:"

msgid "Confirm PIN:"
msgstr "PIN নিশ্চিত করুন:"

msgid "Confirm password:"
msgstr "পাসওয়ার্ড নিশ্চিত করুন:"

msgid "Consent required. Please contact your administrator."
msgstr "সম্মতি প্রয়োজন। অনুগ্রহ করে আপনার প্রশাসকের সঙ্গে যোগাযোগ করুন।"

msgid "Create a PIN to use in place of passwords."
msgstr "পাসওয়ার্ডের পরিবর্তে ব্যবহারের জন্য একটি PIN তৈরি করুন।"

msgid "Device enrollment failed. Please contact your administrator."
msgstr "ডিভাইস নিবন্ধন ব্যর্থ হয়েছে। অনুগ্রহ করে আপনার প্রশাসকের সাথে যোগাযোগ করুন।"

msgid "Device has been removed from the domain."
msgstr "ডিভাইসটি ডোমেইন থেকে সরানো হয়েছে।"

msgid "Enable Bluetooth to sign in with your phone."
msgstr "আপনার ফোন দিয়ে সাইন ইন করতে Bluetooth চালু করুন।"

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Hello PIN নিবন্ধন করা হচ্ছে। অনুগ্রহ করে অপেক্ষা করুন..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "TOTP Authenticator অ্যাপ নিবন্ধন করতে সেটআপ কী '{secret}' লিখুন। কোডের নাম হিসেবে '{issuer}' এবং লেবেল/নাম হিসেবে '{account}' ব্যবহার করুন।"

msgid "Entra Id Fido authentication failed."
msgstr "Entra ID FIDO প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Entra Id Password:"
msgstr "Entra ID পাসওয়ার্ড:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "FIDO প্রমাণীকরণ উপলভ্য নয়। অনুগ্রহ করে অন্য কোনো প্রমাণীকরণ পদ্ধতি চেষ্টা করুন।"

msgid "Failed to authenticate with Hello PIN."
msgstr "Hello PIN দিয়ে প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Hello PIN দিয়ে প্রমাণীকরণ ব্যর্থ হয়েছে। আর একবার চেষ্টা ব্যর্থ হলে মাল্টি-ফ্যাক্টর প্রমাণীকরণ এবং আপনার Linux Hello PIN রিসেট করা প্রয়োজন হবে।"

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Hello TOTP কোড দিয়ে প্রমাণীকরণ করা যায়নি।"

msgid "Failed to build regex: {error}"
msgstr "রেগেক্স তৈরি করতে ব্যর্থ হয়েছে: {error}"

msgid "Failed to change user password: {msg}"
msgstr "ব্যবহারকারীর পাসওয়ার্ড পরিবর্তন করা যায়নি: {msg}"

msgid "Failed to delete CSR key"
msgstr "CSR কী মুছতে ব্যর্থ হয়েছে"

msgid "Failed to delete intune key"
msgstr "Intune কী মুছতে ব্যর্থ হয়েছে"

msgid "Failed to generate QR code"
msgstr "QR কোড তৈরি করতে ব্যর্থ হয়েছে"

msgid "Failed to join domain. Please contact your administrator."
msgstr "ডোমেইনে যোগদান করতে ব্যর্থ হয়েছে। অনুগ্রহ করে আপনার প্রশাসকের সাথে যোগাযোগ করুন।"

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "হ্যালো কী প্রভিশন করতে ব্যর্থ হয়েছে: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "ডিভাইস কনফিগারেশন সংরক্ষণ করতে ব্যর্থ হয়েছে। অনুগ্রহ করে আপনার প্রশাসকের সাথে যোগাযোগ করুন।"

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "ডিভাইসের শংসাপত্র সংরক্ষণ করতে ব্যর্থ হয়েছে। অনুগ্রহ করে আপনার প্রশাসকের সাথে যোগাযোগ করুন।"

msgid "Fido PIN:"
msgstr "Fido PIN:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Himmelblau প্রমাণীকরণ শুরু হচ্ছে, অনুগ্রহ করে অপেক্ষা করুন..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Himmelblau প্রমাণীকরণ পরিষেবা সময়মতো উপলব্ধ হয়নি।"

msgid "Himmelblau authentication service is unavailable."
msgstr "Himmelblau প্রমাণীকরণ পরিষেবা উপলব্ধ নয়।"

msgid "Inputs did not match. Try again."
msgstr "ইনপুটগুলো মেলেনি। আবার চেষ্টা করুন।"

msgid "Invalid credentials"
msgstr "অবৈধ পরিচয়পত্র"

msgid "Multi-factor authentication required."
msgstr "মাল্টি-ফ্যাক্টর প্রমাণীকরণ প্রয়োজন।"

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "মাল্টি-ফ্যাক্টর প্রমাণীকরণ প্রয়োজন। অনুগ্রহ করে আবার সাইন ইন করার চেষ্টা করুন।"

msgid "Network outage detected."
msgstr "নেটওয়ার্ক বিভ্রাট শনাক্ত হয়েছে।"

msgid "New PIN:"
msgstr "নতুন পিন:"

msgid "New password:"
msgstr "নতুন পাসওয়ার্ড:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "কোনো Entra Id Hello PIN প্রদান করা হয়নি।"

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "কোনো Entra Id Hello নিশ্চিতকরণ PIN প্রদান করা হয়নি।"

msgid "No Entra Id confirmation password was supplied."
msgstr "কোনো Entra ID নিশ্চিতকরণ পাসওয়ার্ড সরবরাহ করা হয়নি।"

msgid "No Entra Id password was supplied."
msgstr "কোনো Entra Id পাসওয়ার্ড সরবরাহ করা হয়নি।"

msgid "No Hello TOTP code was supplied."
msgstr "কোনো Hello TOTP কোড প্রদান করা হয়নি।"

msgid "No input was supplied."
msgstr "কোনো ইনপুট সরবরাহ করা হয়নি।"

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "অফলাইন প্রমাণীকরণের মেয়াদ শেষ হয়েছে। চালিয়ে যেতে অনুগ্রহ করে নেটওয়ার্কে সংযুক্ত হন।"

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "আপনার Authenticator অ্যাপ খুলুন এবং সাইন ইন করতে '{entropy}' নম্বরটি লিখুন।"

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "আপনার অথেনটিকেটর অ্যাপ খুলুন এবং নিবন্ধন করতে এই QR কোডটি স্ক্যান করুন। তারপর জেনারেট করা কোডটি লিখুন।\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "PIN-এ পুনরাবৃত্তিমূলক বা অনুমানযোগ্য ধারাবাহিকতা ব্যবহার করা যাবে না। '111111', '123456', বা '135791'-এর মতো প্যাটার্ন এড়িয়ে চলুন।"

msgid "PIN setup failed. Please try signing in again."
msgstr "PIN সেটআপ ব্যর্থ হয়েছে। অনুগ্রহ করে আবার সাইন ইন করার চেষ্টা করুন।"

msgid "PIN:"
msgstr "পিন:"

msgid "Password change required. Please contact your administrator."
msgstr "পাসওয়ার্ড পরিবর্তন করা আবশ্যক। অনুগ্রহ করে আপনার প্রশাসকের সাথে যোগাযোগ করুন।"

msgid "Password entry required."
msgstr "পাসওয়ার্ড লিখতে হবে।"

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "পাসওয়ার্ড রিসেট নিবন্ধন প্রয়োজন। অন্য ডিভাইস থেকে https://aka.ms/ssprsetup-এ সেটআপ সম্পূর্ণ করুন, তারপর আবার চেষ্টা করুন।"

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "অনুগ্রহ করে আপনার Authenticator থেকে আপনার Hello TOTP কোড লিখুন:"

msgid "Please insert your security key."
msgstr "আপনার নিরাপত্তা কী প্রবেশ করান।"

msgid "Please select a device by touching one of them."
msgstr "অনুগ্রহ করে ডিভাইসগুলোর একটিতে স্পর্শ করে একটি ডিভাইস নির্বাচন করুন।"

msgid "Please touch your security key."
msgstr "আপনার নিরাপত্তা কী স্পর্শ করুন।"

msgid "Press enter to continue"
msgstr "চালিয়ে যেতে Enter চাপুন"

msgid "QR/Bluetooth authentication failed."
msgstr "QR/Bluetooth প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "সাইন-ইন চালিয়ে যেতে QR কোডটি স্ক্যান করুন, অথবা অন্য ডিভাইসে এই লিংকটি খুলুন:\n"
"{complete}\n"
"স্ক্যান করতে না পারলে, ভিজিট করুন:\n"
"{verification_uri}\n"
"এবং কোডটি লিখুন:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "আপনার অথেন্টিকেটর অ্যাপ দিয়ে স্ক্যান করুন"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "নিরাপত্তা কী এবং QR/Bluetooth প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Security key authentication failed."
msgstr "নিরাপত্তা কী প্রমাণীকরণ ব্যর্থ হয়েছে।"

msgid "Session data corrupted. Please sign in again."
msgstr "সেশনের ডেটা ক্ষতিগ্রস্ত হয়েছে। অনুগ্রহ করে আবার সাইন ইন করুন।"

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "একটি PIN সেট আপ করুন\n"
"Hello PIN হলো আপনার ডিভাইস, অ্যাপ এবং পরিষেবাগুলিতে সাইন ইন করার একটি দ্রুত ও নিরাপদ উপায়।"

msgid "TOTP Code:"
msgstr "TOTP কোড:"

msgid "The minimum PIN length is {length} characters."
msgstr "ন্যূনতম PIN দৈর্ঘ্য {length} অক্ষর।"

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "এই কমান্ডটি আপনার স্থানীয় Hello PIN পরিবর্তন করে, আপনার Entra Id পাসওয়ার্ড নয়।"

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "পরপর অনেকবার ব্যর্থ প্রচেষ্টা হয়েছে। আপনার ডিভাইসটি সাময়িকভাবে ব্লক করা হয়েছে। অনুগ্রহ করে এটি আনপ্লাগ করে আবার প্লাগ ইন করুন।"

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "অনেকবার ব্যর্থ প্রচেষ্টা করা হয়েছে। আপনার ডিভাইসটি ব্লক করা হয়েছে। এটি রিসেট করুন।"

msgid "Too many failed user verification attempts."
msgstr "ব্যবহারকারী যাচাইকরণের ব্যর্থ প্রচেষ্টার সংখ্যা খুব বেশি।"

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "অনেকবার ভুল PIN দেওয়া হয়েছে। আপনাকে একটি নতুন Linux Hello PIN নিবন্ধন করতে হবে।"

msgid "Try again."
msgstr "আবার চেষ্টা করুন।"

msgid "Unexpected authentication step. Please try signing in again."
msgstr "অপ্রত্যাশিত প্রমাণীকরণ ধাপ। অনুগ্রহ করে আবার সাইন ইন করার চেষ্টা করুন।"

msgid "Unexpected error occurred."
msgstr "অপ্রত্যাশিত ত্রুটি ঘটেছে।"

msgid "Unexpected error: {error}"
msgstr "অপ্রত্যাশিত ত্রুটি: {error}"

msgid "Unexpected select device notice"
msgstr "অপ্রত্যাশিত ডিভাইস নির্বাচন বিজ্ঞপ্তি"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "আপনার পাসওয়ার্ড আপডেট করুন\n"
"আপনাকে আপনার পাসওয়ার্ড আপডেট করতে হবে, কারণ এটি\n"
"আপনার প্রথমবার সাইন ইন করা, অথবা আপনার\n"
"পাসওয়ার্ডের মেয়াদ শেষ হয়ে গেছে।"

msgid "Use the Linux Hello PIN for this device."
msgstr "এই ডিভাইসের জন্য Linux Hello PIN ব্যবহার করুন।"

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "আপনার Office 365 বা Microsoft অনলাইন লগইনের পাসওয়ার্ড ব্যবহার করুন।"

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "অন্য ডিভাইসে একটি ব্রাউজার ব্যবহার করে এখানে যান:\n"
"{verification_uri}\n"
"এবং কোডটি লিখুন:\n"
"{user_code}"

msgid "Value:"
msgstr "মান:"

msgid "Waiting for browser authentication to complete..."
msgstr "ব্রাউজার প্রমাণীকরণ সম্পূর্ণ হওয়ার জন্য অপেক্ষা করা হচ্ছে..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "আমরা আপনার ফোন {phone}-এ টেক্সট করেছি। সাইন ইন করতে অনুগ্রহ করে কোডটি লিখুন:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "আমরা আপনার অফিসের ফোন {phone} নম্বরে কল করছি। চালিয়ে যেতে অনুগ্রহ করে কলটি ধরুন।"

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "আমরা আপনার ফোন {phone}-এ কল করছি। চালিয়ে যেতে অনুগ্রহ করে কলটি ধরুন।"

msgid "Wrong PIN! {message}"
msgstr "ভুল PIN! {message}"

msgid "Wrong user verification! {message}"
msgstr "ব্যবহারকারী যাচাইকরণ ভুল হয়েছে! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "আপনার আর {attempts}টি প্রচেষ্টা বাকি আছে।"
msgstr[1] "আপনার আর {attempts}টি প্রচেষ্টা বাকি আছে।"

msgid "Your session has expired. Please sign in again."
msgstr "আপনার সেশনের মেয়াদ শেষ হয়ে গেছে। অনুগ্রহ করে আবার সাইন ইন করুন।"

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"আপনাকে এখন pam_unix থেকে পাসওয়ার্ডের জন্য অনুরোধ করা হলে, অনুগ্রহ করে সেই অনুরোধটি উপেক্ষা করুন, ফিরে যান এবং আবার চেষ্টা করুন।"

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"পুশ পাচ্ছেন না? আপনার মোবাইল ডিভাইসের ইন্টারনেট সংযোগ পরীক্ষা করুন।"
