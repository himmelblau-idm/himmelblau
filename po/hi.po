msgid "An unexpected error occurred."
msgstr "एक अप्रत्याशित त्रुटि हुई।"

msgid "Approve sign-in in your authenticator app, then wait..."
msgstr "अपने प्रमाणक ऐप में साइन-इन को स्वीकृत करें, फिर प्रतीक्षा करें..."

msgid "Authenticated user {user} does not match requested user"
msgstr "प्रमाणित उपयोगकर्ता {user} अनुरोधित उपयोगकर्ता से मेल नहीं खाता"

msgid "Authenticated user {uuid} does not match requested user"
msgstr "प्रमाणित उपयोगकर्ता {uuid} अनुरोधित उपयोगकर्ता से मेल नहीं खाता"

msgid "Authentication did not return a refresh token. Please try again."
msgstr "प्रमाणीकरण ने रिफ्रेश टोकन वापस नहीं किया। कृपया फिर से प्रयास करें।"

msgid "Authentication failed (AADSTS{code})"
msgstr "प्रमाणीकरण विफल रहा (AADSTS{code})"

msgid "Authentication failed in browser flow."
msgstr "ब्राउज़र प्रवाह में प्रमाणीकरण विफल रहा।"

msgid "Authentication failed. Please contact your administrator."
msgstr "प्रमाणीकरण विफल रहा। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Authentication failed. Please try again."
msgstr "प्रमाणीकरण विफल रहा। कृपया पुनः प्रयास करें।"

msgid "Authentication failed. Please try signing in again."
msgstr "प्रमाणीकरण विफल रहा। कृपया फिर से साइन इन करने का प्रयास करें।"

msgid "Authentication failed: Authentication method not supported."
msgstr "प्रमाणीकरण विफल: प्रमाणीकरण विधि समर्थित नहीं है।"

msgid "Authentication failed: Configuration error."
msgstr "प्रमाणीकरण विफल: कॉन्फ़िगरेशन त्रुटि।"

msgid "Authentication failed: Cryptographic error."
msgstr "प्रमाणीकरण विफल: क्रिप्टोग्राफ़िक त्रुटि।"

msgid "Authentication failed: Invalid server response."
msgstr "प्रमाणीकरण विफल: अमान्य सर्वर प्रतिक्रिया।"

msgid "Authentication failed: Missing required data."
msgstr "प्रमाणीकरण विफल: आवश्यक डेटा मौजूद नहीं है।"

msgid "Authentication failed: Security hardware error."
msgstr "प्रमाणीकरण विफल: सुरक्षा हार्डवेयर त्रुटि।"

msgid "Authentication failed: Unable to reach authentication server."
msgstr "प्रमाणीकरण विफल रहा: प्रमाणीकरण सर्वर तक पहुँचने में असमर्थ।"

msgid "Authentication failed: {error}"
msgstr "प्रमाणीकरण विफल रहा: {error}"

msgid "Authentication flow completed but token exchange failed. Please try again."
msgstr "प्रमाणीकरण प्रवाह पूरा हो गया, लेकिन टोकन एक्सचेंज विफल रहा। कृपया फिर से प्रयास करें।"

msgid "Authentication in progress."
msgstr "प्रमाणीकरण प्रगति पर है।"

msgid "Authentication incomplete. Please try again."
msgstr "प्रमाणीकरण अधूरा है। कृपया फिर से प्रयास करें।"

msgid "Authentication service is temporarily unavailable. Please try again shortly."
msgstr "प्रमाणीकरण सेवा अस्थायी रूप से उपलब्ध नहीं है। कृपया थोड़ी देर बाद फिर से प्रयास करें।"

msgid "Authentication service unavailable. Please try again later."
msgstr "प्रमाणीकरण सेवा उपलब्ध नहीं है। कृपया बाद में पुनः प्रयास करें।"

msgid "Authentication session corrupted. Please try again."
msgstr "प्रमाणीकरण सत्र दूषित हो गया है। कृपया पुनः प्रयास करें।"

msgid "Authentication session data missing. Please try again."
msgstr "प्रमाणीकरण सत्र डेटा अनुपलब्ध है। कृपया फिर से प्रयास करें।"

msgid "Authentication session returned an unexpected state. Please try again."
msgstr "प्रमाणीकरण सत्र ने एक अप्रत्याशित स्थिति लौटाई। कृपया फिर से प्रयास करें।"

msgid "Authentication timed out. Please try again."
msgstr "प्रमाणीकरण का समय समाप्त हो गया। कृपया पुनः प्रयास करें।"

msgid "Browser authentication backend unavailable. Please try again."
msgstr "ब्राउज़र प्रमाणीकरण बैकएंड अनुपलब्ध है। कृपया फिर से प्रयास करें।"

msgid "Changing the password. Please wait..."
msgstr "पासवर्ड बदला जा रहा है। कृपया प्रतीक्षा करें..."

msgid "Chosen password is too short! 8 chars required."
msgstr "चुना गया पासवर्ड बहुत छोटा है! 8 वर्ण आवश्यक हैं।"

msgid "Chosen pin is too short! {length} chars required."
msgstr "चुना गया पिन बहुत छोटा है! {length} वर्ण आवश्यक हैं।"

msgid "Cloud Password:"
msgstr "क्लाउड पासवर्ड:"

msgid "Code:"
msgstr "कोड:"

msgid "Confirm PIN:"
msgstr "पिन की पुष्टि करें:"

msgid "Confirm password:"
msgstr "पासवर्ड की पुष्टि करें:"

msgid "Consent required. Please contact your administrator."
msgstr "सहमति आवश्यक है। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Create a PIN to use in place of passwords."
msgstr "पासवर्ड के स्थान पर उपयोग करने के लिए एक PIN बनाएं।"

msgid "Device enrollment failed. Please contact your administrator."
msgstr "डिवाइस नामांकन विफल रहा। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Device has been removed from the domain."
msgstr "डिवाइस को डोमेन से हटा दिया गया है।"

msgid "Enable Bluetooth to sign in with your phone."
msgstr "अपने फ़ोन से साइन इन करने के लिए Bluetooth सक्षम करें।"

msgid "Enrolling the Hello PIN. Please wait..."
msgstr "Hello PIN नामांकित किया जा रहा है। कृपया प्रतीक्षा करें..."

msgid "Enter the setup key '{secret}' to enroll a TOTP Authenticator app. Use '{issuer}' for the code name and '{account}' as the label/name."
msgstr "TOTP Authenticator ऐप नामांकित करने के लिए सेटअप कुंजी '{secret}' दर्ज करें। कोड नाम के लिए '{issuer}' और लेबल/नाम के रूप में '{account}' का उपयोग करें।"

msgid "Entra Id Fido authentication failed."
msgstr "Entra ID FIDO प्रमाणीकरण विफल रहा।"

msgid "Entra Id Password:"
msgstr "Entra Id पासवर्ड:"

msgid "FIDO authentication not available. Please try a different authentication method."
msgstr "FIDO प्रमाणीकरण उपलब्ध नहीं है। कृपया कोई अन्य प्रमाणीकरण विधि आज़माएँ।"

msgid "Failed to authenticate with Hello PIN."
msgstr "Hello PIN से प्रमाणीकरण करने में विफल।"

msgid "Failed to authenticate with Hello PIN. One more failed attempt will require multi-factor authentication and resetting your Linux Hello PIN."
msgstr "Hello PIN से प्रमाणीकरण विफल रहा। एक और विफल प्रयास पर बहु-कारक प्रमाणीकरण और आपके Linux Hello PIN को रीसेट करना आवश्यक होगा।"

msgid "Failed to authenticate with Hello TOTP code."
msgstr "Hello TOTP कोड से प्रमाणीकरण विफल रहा।"

msgid "Failed to build regex: {error}"
msgstr "रेगेक्स बनाने में विफल: {error}"

msgid "Failed to change user password: {msg}"
msgstr "उपयोगकर्ता पासवर्ड बदलने में विफल: {msg}"

msgid "Failed to delete CSR key"
msgstr "CSR कुंजी हटाने में विफल रहा"

msgid "Failed to delete intune key"
msgstr "Intune कुंजी हटाने में विफल रहा"

msgid "Failed to generate QR code"
msgstr "QR कोड जनरेट करने में विफल रहा"

msgid "Failed to join domain. Please contact your administrator."
msgstr "डोमेन से जुड़ने में विफल। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Failed to provision hello key: {error}\n"
"{message}"
msgstr "हैलो कुंजी प्रोविज़न करने में विफल: {error}\n"
"{message}"

msgid "Failed to save device configuration. Please contact your administrator."
msgstr "डिवाइस कॉन्फ़िगरेशन सहेजने में विफल। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Failed to store device credentials. Please contact your administrator."
msgstr "डिवाइस क्रेडेंशियल संग्रहीत करने में विफल। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Fido PIN:"
msgstr "FIDO पिन:"

msgid "Himmelblau authentication is starting, please wait..."
msgstr "Himmelblau प्रमाणीकरण शुरू हो रहा है, कृपया प्रतीक्षा करें..."

msgid "Himmelblau authentication service did not become available in time."
msgstr "Himmelblau प्रमाणीकरण सेवा समय पर उपलब्ध नहीं हो सकी।"

msgid "Himmelblau authentication service is unavailable."
msgstr "Himmelblau प्रमाणीकरण सेवा उपलब्ध नहीं है।"

msgid "Inputs did not match. Try again."
msgstr "इनपुट मेल नहीं खाते। फिर से प्रयास करें।"

msgid "Invalid credentials"
msgstr "अमान्य क्रेडेंशियल्स"

msgid "Multi-factor authentication required."
msgstr "बहु-कारक प्रमाणीकरण आवश्यक है।"

msgid "Multi-factor authentication required. Please try signing in again."
msgstr "मल्टी-फ़ैक्टर प्रमाणीकरण आवश्यक है। कृपया फिर से साइन इन करने का प्रयास करें।"

msgid "Network outage detected."
msgstr "नेटवर्क आउटेज का पता चला।"

msgid "New PIN:"
msgstr "नया PIN:"

msgid "New password:"
msgstr "नया पासवर्ड:"

msgid "No Entra Id Hello PIN was supplied."
msgstr "कोई Entra ID Hello PIN प्रदान नहीं किया गया।"

msgid "No Entra Id Hello confirmation PIN was supplied."
msgstr "कोई Entra ID Hello पुष्टिकरण PIN प्रदान नहीं किया गया।"

msgid "No Entra Id confirmation password was supplied."
msgstr "कोई Entra Id पुष्टिकरण पासवर्ड प्रदान नहीं किया गया था।"

msgid "No Entra Id password was supplied."
msgstr "कोई Entra Id पासवर्ड प्रदान नहीं किया गया था।"

msgid "No Hello TOTP code was supplied."
msgstr "कोई Hello TOTP कोड प्रदान नहीं किया गया।"

msgid "No input was supplied."
msgstr "कोई इनपुट प्रदान नहीं किया गया था।"

msgid "Offline auth has expired. Please connect to the network to continue."
msgstr "ऑफ़लाइन प्रमाणीकरण की अवधि समाप्त हो गई है। जारी रखने के लिए कृपया नेटवर्क से कनेक्ट करें।"

msgid "Open your Authenticator app, and enter the number '{entropy}' to sign in."
msgstr "अपना Authenticator ऐप खोलें, और साइन इन करने के लिए संख्या '{entropy}' दर्ज करें।"

msgid "Open your authenticator app and scan this QR code to enroll. Then enter the generated code.\n"
"{qr}"
msgstr "अपना ऑथेंटिकेटर ऐप खोलें और नामांकन के लिए इस QR कोड को स्कैन करें। फिर जनरेट किया गया कोड दर्ज करें।\n"
"{qr}"

msgid "PIN must not use repeating or predictable sequences. Avoid patterns like '111111', '123456', or '135791'."
msgstr "पिन में दोहराए जाने वाले या अनुमान लगाने योग्य क्रमों का उपयोग नहीं होना चाहिए। '111111', '123456' या '135791' जैसे पैटर्न से बचें।"

msgid "PIN setup failed. Please try signing in again."
msgstr "PIN सेटअप विफल रहा। कृपया फिर से साइन इन करने का प्रयास करें।"

msgid "PIN:"
msgstr "पिन:"

msgid "Password change required. Please contact your administrator."
msgstr "पासवर्ड बदलना आवश्यक है। कृपया अपने व्यवस्थापक से संपर्क करें।"

msgid "Password entry required."
msgstr "पासवर्ड दर्ज करना आवश्यक है।"

msgid "Password reset registration required. Complete setup at https://aka.ms/ssprsetup from another device, then try again."
msgstr "पासवर्ड रीसेट पंजीकरण आवश्यक है। किसी अन्य डिवाइस से https://aka.ms/ssprsetup पर सेटअप पूरा करें, फिर दोबारा प्रयास करें।"

msgid "Please enter your Hello TOTP code from your Authenticator:"
msgstr "कृपया अपने Authenticator से अपना Hello TOTP कोड दर्ज करें:"

msgid "Please insert your security key."
msgstr "कृपया अपनी सुरक्षा कुंजी डालें।"

msgid "Please select a device by touching one of them."
msgstr "कृपया उनमें से किसी एक को स्पर्श करके कोई डिवाइस चुनें।"

msgid "Please touch your security key."
msgstr "कृपया अपनी सुरक्षा कुंजी को स्पर्श करें।"

msgid "Press enter to continue"
msgstr "जारी रखने के लिए Enter दबाएं"

msgid "QR/Bluetooth authentication failed."
msgstr "QR/ब्लूटूथ प्रमाणीकरण विफल रहा।"

msgid "Scan the QR code to continue sign-in, or open this link on another device:\n"
"{complete}\n"
"If you cannot scan, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "साइन-इन जारी रखने के लिए QR कोड स्कैन करें, या इस लिंक को किसी अन्य डिवाइस पर खोलें:\n"
"{complete}\n"
"यदि आप स्कैन नहीं कर सकते, तो यहां जाएं:\n"
"{verification_uri}\n"
"और कोड दर्ज करें:\n"
"{user_code}"

msgid "Scan with your authenticator app"
msgstr "अपने प्रमाणक ऐप से स्कैन करें"

msgid "Security key and QR/Bluetooth authentication failed."
msgstr "सुरक्षा कुंजी और QR/Bluetooth प्रमाणीकरण विफल रहा।"

msgid "Security key authentication failed."
msgstr "सुरक्षा कुंजी प्रमाणीकरण विफल हो गया।"

msgid "Session data corrupted. Please sign in again."
msgstr "सत्र डेटा दूषित हो गया है। कृपया फिर से साइन इन करें।"

msgid "Set up a PIN\n"
"A Hello PIN is a fast, secure way to sign in to your device, apps, and services."
msgstr "पिन सेट अप करें\n"
"Hello पिन आपके डिवाइस, ऐप्स और सेवाओं में साइन इन करने का एक तेज़, सुरक्षित तरीका है।"

msgid "TOTP Code:"
msgstr "TOTP कोड:"

msgid "The minimum PIN length is {length} characters."
msgstr "न्यूनतम PIN लंबाई {length} वर्ण है।"

msgid "This command changes your local Hello PIN, NOT your Entra Id password."
msgstr "यह कमांड आपका स्थानीय Hello PIN बदलती है, आपका Entra Id पासवर्ड नहीं।"

msgid "Too many failed attempts in one row. Your device has been temporarily blocked. Please unplug it and plug in again."
msgstr "एक ही पंक्ति में बहुत अधिक असफल प्रयास हुए। आपका डिवाइस अस्थायी रूप से ब्लॉक कर दिया गया है। कृपया इसे अनप्लग करें और फिर से प्लग इन करें।"

msgid "Too many failed attempts. Your device has been blocked. Reset it."
msgstr "बहुत अधिक असफल प्रयास हुए हैं। आपका डिवाइस ब्लॉक कर दिया गया है। इसे रीसेट करें।"

msgid "Too many failed user verification attempts."
msgstr "बहुत अधिक उपयोगकर्ता सत्यापन प्रयास विफल रहे।"

msgid "Too many incorrect PIN attempts. You will need to enroll a new Linux Hello PIN."
msgstr "बहुत अधिक बार गलत PIN दर्ज किया गया है। आपको नया Linux Hello PIN नामांकित करना होगा।"

msgid "Try again."
msgstr "फिर से प्रयास करें।"

msgid "Unexpected authentication step. Please try signing in again."
msgstr "अप्रत्याशित प्रमाणीकरण चरण। कृपया फिर से साइन इन करने का प्रयास करें।"

msgid "Unexpected error occurred."
msgstr "एक अनपेक्षित त्रुटि हुई।"

msgid "Unexpected error: {error}"
msgstr "अप्रत्याशित त्रुटि: {error}"

msgid "Unexpected select device notice"
msgstr "अनपेक्षित डिवाइस चयन सूचना"

msgid "Update your password\n"
"You need to update your password because this is\n"
"the first time you are signing in, or because your\n"
"password has expired."
msgstr "अपना पासवर्ड अपडेट करें\n"
"आपको अपना पासवर्ड अपडेट करना होगा क्योंकि यह\n"
"आपके साइन इन करने का पहला अवसर है, या क्योंकि आपका\n"
"पासवर्ड समाप्त हो गया है।"

msgid "Use the Linux Hello PIN for this device."
msgstr "इस डिवाइस के लिए Linux Hello PIN का उपयोग करें।"

msgid "Use the password for your Office 365 or Microsoft online login."
msgstr "अपने Office 365 या Microsoft ऑनलाइन लॉगिन का पासवर्ड उपयोग करें।"

msgid "Using a browser on another device, visit:\n"
"{verification_uri}\n"
"And enter the code:\n"
"{user_code}"
msgstr "किसी अन्य डिवाइस पर ब्राउज़र का उपयोग करके यहां जाएं:\n"
"{verification_uri}\n"
"और कोड दर्ज करें:\n"
"{user_code}"

msgid "Value:"
msgstr "मान:"

msgid "Waiting for browser authentication to complete..."
msgstr "ब्राउज़र प्रमाणीकरण पूरा होने की प्रतीक्षा की जा रही है..."

msgid "We texted your phone {phone}. Please enter the code to sign in:"
msgstr "हमने आपके फ़ोन {phone} पर टेक्स्ट संदेश भेजा है। साइन इन करने के लिए कृपया कोड दर्ज करें:"

msgid "We're calling your office phone {phone}. Please answer it to continue."
msgstr "हम आपके कार्यालय के फ़ोन {phone} पर कॉल कर रहे हैं। जारी रखने के लिए कृपया इसका उत्तर दें।"

msgid "We're calling your phone {phone}. Please answer it to continue."
msgstr "हम आपके फ़ोन {phone} पर कॉल कर रहे हैं। जारी रखने के लिए कृपया इसका उत्तर दें।"

msgid "Wrong PIN! {message}"
msgstr "गलत PIN! {message}"

msgid "Wrong user verification! {message}"
msgstr "गलत उपयोगकर्ता सत्यापन! {message}"

msgid "You have {attempts} attempt left."
msgid_plural "You have {attempts} attempts left."
msgstr[0] "आपके पास {attempts} प्रयास शेष है।"
msgstr[1] "आपके पास {attempts} प्रयास शेष हैं।"

msgid "Your session has expired. Please sign in again."
msgstr "आपका सत्र समाप्त हो गया है। कृपया फिर से साइन इन करें।"

msgid "{code}: {message}\n"
"If you are now prompted for a password from pam_unix, please disregard the prompt, go back and try again."
msgstr "{code}: {message}\n"
"यदि अब आपसे pam_unix द्वारा पासवर्ड मांगा जाता है, तो कृपया उस संकेत को अनदेखा करें, वापस जाएं और फिर से प्रयास करें।"

msgid "{message}\n"
"No push? Check your mobile device's internet connection."
msgstr "{message}\n"
"पुश नहीं मिला? अपने मोबाइल डिवाइस का इंटरनेट कनेक्शन जांचें।"
