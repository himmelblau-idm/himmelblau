#!/bin/sh
set -e
if command -v selinuxenabled >/dev/null 2>&1 && selinuxenabled; then
  if command -v semodule >/dev/null 2>&1; then
    semodule -i /usr/share/selinux/packages/himmelblaud.pp || true
    restorecon -R -v \
      /usr/sbin/himmelblaud \
      /usr/sbin/himmelblaud_tasks \
      /etc/himmelblau \
      /var/log/himmelblau \
      /run/himmelblau 2>/dev/null || true
  fi
fi
exit 0
