policy_module(himmelblaud, 1.0)

########################################
# Domains for your daemons

type himmelblaud_t;
type himmelblaud_exec_t;
init_daemon_domain(himmelblaud_t, himmelblaud_exec_t)

type himmelblaud_tasks_t;
type himmelblaud_tasks_exec_t;
init_daemon_domain(himmelblaud_tasks_t, himmelblaud_tasks_exec_t)

# Share common rules across both daemons via an attribute
attribute himmelblau_daemon;
typeattribute himmelblaud_t himmelblau_daemon;
typeattribute himmelblaud_tasks_t himmelblau_daemon;

########################################
# App-specific file types

# config: /etc/himmelblau(/.*)?
type himmelblau_etc_t;
files_config_file(himmelblau_etc_t)

# logs: /var/log/himmelblau(/.*)?
type himmelblau_log_t;
logging_log_file(himmelblau_log_t)

# runtime: /run/himmelblau(/.*)?
type himmelblau_var_run_t;
files_pid_file(himmelblau_var_run_t)

########################################
# Minimal, practical access

# read config
allow himmelblau_daemon himmelblau_etc_t:dir  { read search open getattr };
allow himmelblau_daemon himmelblau_etc_t:file { read open getattr };

# write logs
allow himmelblau_daemon himmelblau_log_t:dir  { search open getattr add_name create write };
allow himmelblau_daemon himmelblau_log_t:file { create write append open getattr };

# create pid/sockets in /run/himmelblau
allow himmelblau_daemon himmelblau_var_run_t:dir  { search open getattr add_name create write remove_name };
allow himmelblau_daemon himmelblau_var_run_t:file { create write open getattr unlink };

########################################
# Networking / DBus hooks (enable as needed)
# corenet_tcp_bind_http_port(himmelblaud_t)
# corenet_tcp_connect_all_ports(himmelblaud_tasks_t)
# dbus_system_bus_client(himmelblaud_t)
# dbus_system_bus_client(himmelblaud_tasks_t)
# polkitd_dbus_chat(himmelblaud_t)
# polkitd_dbus_chat(himmelblaud_tasks_t)
