#!/bin/sh
set -e

# Detect if running on a Live system where service start should be skipped
is_live_system() {
    grep -q 'boot=live' /proc/cmdline 2>/dev/null && return 0
    grep -q 'rd.live' /proc/cmdline 2>/dev/null && return 0
    [ -d /run/live ] && return 0
    [ -f /.live-installer ] && return 0
    systemd-detect-virt -c -q 2>/dev/null && return 0
    return 1
}

# Returns success if SELinux is disabled or the policy is already loaded.
selinux_policy_loaded() {
    if ! command -v selinuxenabled >/dev/null 2>&1; then
        return 0
    fi

    if ! selinuxenabled; then
        return 0
    fi

    if [ ! -d /usr/share/selinux/packages/himmelblaud ]; then
        return 0
    fi

    if ! command -v semodule >/dev/null 2>&1; then
        return 1
    fi

    semodule -l 2>/dev/null | awk '{print $1}' | grep -qx himmelblaud
}

skip_start=0
if ! selinux_policy_loaded; then
    skip_start=1
fi

if command -v deb-systemd-helper >/dev/null 2>&1; then
    if [ "$1" != "configure" ]; then
        exit 0
    fi

    deb-systemd-helper unmask himmelblaud-orchestrator.service >/dev/null || true

    if deb-systemd-helper --quiet was-enabled himmelblaud-orchestrator.service; then
        deb-systemd-helper enable himmelblaud-orchestrator.service >/dev/null || true
    else
        deb-systemd-helper update-state himmelblaud-orchestrator.service >/dev/null || true
    fi

    if [ -z "$DPKG_ROOT" ] && [ -d /run/systemd/system ] && ! is_live_system; then
        deb-systemd-invoke daemon-reload --system >/dev/null || true
        if [ "$skip_start" -eq 1 ]; then
            echo "SELinux enabled but himmelblaud policy not loaded yet; deferring orchestrator service start"
        else
            deb-systemd-invoke restart himmelblaud-orchestrator.service >/dev/null || true
        fi
    fi
elif command -v systemctl >/dev/null 2>&1; then
    if [ -d /run/systemd/system ] && ! is_live_system; then
        systemctl daemon-reload >/dev/null || true
        systemctl enable himmelblaud-orchestrator.service >/dev/null || true
        if [ "$skip_start" -eq 1 ]; then
            echo "SELinux enabled but himmelblaud policy not loaded yet; deferring orchestrator service start"
        else
            systemctl restart himmelblaud-orchestrator.service >/dev/null || true
        fi
    fi
fi

# Ensure orchestrator cache directories are created immediately after install
systemd-tmpfiles --create /usr/lib/tmpfiles.d/himmelblaud-orchestrator.conf 2>/dev/null || systemd-tmpfiles --create /usr/lib/x86_64-linux-gnu/tmpfiles.d/himmelblaud-orchestrator.conf 2>/dev/null || true
