#!/bin/sh
set -e

# Detect if running on a Live system where service start should be skipped
is_live_system() {
    grep -q 'boot=live' /proc/cmdline 2>/dev/null && return 0
    grep -q 'rd.live' /proc/cmdline 2>/dev/null && return 0
    [ -d /run/live ] && return 0
    [ -f /.live-installer ] && return 0
    systemd-detect-virt -c -q 2>/dev/null && return 0
    return 1
}

# Returns success if SELinux is disabled or the policy is already loaded.
selinux_policy_loaded() {
    if ! command -v selinuxenabled >/dev/null 2>&1; then
        return 0
    fi

    if ! selinuxenabled; then
        return 0
    fi

    if [ ! -d /usr/share/selinux/packages/himmelblaud ]; then
        return 0
    fi

    if ! command -v semodule >/dev/null 2>&1; then
        return 1
    fi

    semodule -l 2>/dev/null | awk '{print $1}' | grep -qx himmelblaud
}

build_orchestrator_container() {
    CONTAINER_BUILD_DIR="/usr/share/himmelblau/orchestrator-container"
    IMAGE_TAG="localhost/himmelblau/playwright-orchestrator:latest"
    BRIDGE_PROTOCOL_LABEL="org.himmelblau.orchestrator.bridge_protocol"
    BRIDGE_PROTOCOL_VERSION="0.2"

    # Skip when package tools are installing into an alternate root.
    if [ -n "$DPKG_ROOT" ]; then
        return 0
    fi

    # Skip on live systems (installer media)
    if is_live_system; then
        return 0
    fi

    # Check if podman is available
    if ! command -v podman >/dev/null 2>&1; then
        echo "Warning: podman not found, skipping orchestrator container build" >&2
        return 0
    fi

    if podman image exists "$IMAGE_TAG" >/dev/null 2>&1; then
        current_protocol="$(podman image inspect --format "{{ index .Config.Labels \"$BRIDGE_PROTOCOL_LABEL\" }}" "$IMAGE_TAG" 2>/dev/null || true)"
        if [ "$current_protocol" = "$BRIDGE_PROTOCOL_VERSION" ]; then
            return 0
        fi
        echo "Existing orchestrator container image has stale bridge protocol '$current_protocol'; rebuilding..."
    fi

    # Check if build directory exists
    if [ ! -d "$CONTAINER_BUILD_DIR" ]; then
        echo "Warning: orchestrator container build directory not found at $CONTAINER_BUILD_DIR" >&2
        return 0
    fi

    # Check if Dockerfile exists
    if [ ! -f "$CONTAINER_BUILD_DIR/Dockerfile" ]; then
        echo "Warning: orchestrator Dockerfile not found" >&2
        return 0
    fi

    echo "Building orchestrator browser container image; this may take several minutes while Chromium and Playwright dependencies are installed..."
    if podman build --layers -t "$IMAGE_TAG" "$CONTAINER_BUILD_DIR" 2>&1; then
        echo "Orchestrator container image built successfully: $IMAGE_TAG"
        return 0
    else
        echo "Warning: Failed to build orchestrator container image" >&2
        echo "The orchestrator service may not function until the container is built manually" >&2
        echo "To build manually: podman build --layers -t $IMAGE_TAG $CONTAINER_BUILD_DIR" >&2
        return 0
    fi
}

# Build the orchestrator container during package installation/upgrade
build_orchestrator_container

# Ensure orchestrator cache and container runtime directories exist before any
# package-triggered service restart. These /run paths are volatile, and the
# hardened unit can only grant ReadWritePaths for paths that already exist.
systemd-tmpfiles --create /usr/lib/tmpfiles.d/himmelblaud-orchestrator.conf 2>/dev/null || systemd-tmpfiles --create /usr/lib/x86_64-linux-gnu/tmpfiles.d/himmelblaud-orchestrator.conf 2>/dev/null || true

skip_start=0
if ! selinux_policy_loaded; then
    skip_start=1
fi

if command -v deb-systemd-helper >/dev/null 2>&1; then
    if [ "$1" != "configure" ]; then
        exit 0
    fi

    deb-systemd-helper unmask himmelblaud-orchestrator.service >/dev/null || true

    if deb-systemd-helper --quiet was-enabled himmelblaud-orchestrator.service; then
        deb-systemd-helper enable himmelblaud-orchestrator.service >/dev/null || true
    else
        deb-systemd-helper update-state himmelblaud-orchestrator.service >/dev/null || true
    fi

    if [ -z "$DPKG_ROOT" ] && [ -d /run/systemd/system ] && ! is_live_system; then
        deb-systemd-invoke daemon-reload --system >/dev/null || true
        if [ "$skip_start" -eq 1 ]; then
            echo "SELinux enabled but himmelblaud policy not loaded yet; deferring orchestrator service start"
        else
            deb-systemd-invoke restart himmelblaud-orchestrator.service >/dev/null || true
        fi
    fi
elif command -v systemctl >/dev/null 2>&1; then
    if [ -d /run/systemd/system ] && ! is_live_system; then
        systemctl daemon-reload >/dev/null || true
        systemctl enable himmelblaud-orchestrator.service >/dev/null || true
        if [ "$skip_start" -eq 1 ]; then
            echo "SELinux enabled but himmelblaud policy not loaded yet; deferring orchestrator service start"
        else
            systemctl restart himmelblaud-orchestrator.service >/dev/null || true
        fi
    fi
fi
